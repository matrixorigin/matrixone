set -eu

usage() {
    echo "usage: $0 [go test flags and package patterns...]" >&2
    echo "example: $0 -race -count=1 -timeout=120s ./pkg/target/..." >&2
}

if [ "$#" -eq 0 ]; then
    usage
    exit 2
fi

script_dir=$(CDPATH= cd -P "$(dirname "$0")" && pwd)
repo_root=$(git -C "$script_dir" rev-parse --show-toplevel)
case "$repo_root" in
    *[[:space:]]*)
        echo "MatrixOne's Make/CGo flags require a repository path without whitespace: $repo_root" >&2
        exit 1
        ;;
esac
cgo_dir="$repo_root/cgo"
thirdparty_dir="$repo_root/thirdparties/install"
lib_dir="$thirdparty_dir/lib"
include_dir="$thirdparty_dir/include"

goos=$(go env GOOS)
gohostos=$(go env GOHOSTOS)
goarch=$(go env GOARCH)
gohostarch=$(go env GOHOSTARCH)

if [ "$goos" != "$gohostos" ] || [ "$goarch" != "$gohostarch" ]; then
    echo "local MatrixOne CGo tests do not support cross compilation:" \
        "target=$goos/$goarch, host=$gohostos/$gohostarch" >&2
    exit 1
fi
if [ "$(go env CGO_ENABLED)" != "1" ]; then
    echo "MatrixOne CGo tests require CGO_ENABLED=1" >&2
    exit 1
fi

case "$goos" in
    darwin)
        libmo="$cgo_dir/libmo.dylib"
        libusearch="$lib_dir/libusearch_c.dylib"
        runtime_path_var=DYLD_LIBRARY_PATH
        platform_link_flags=
        ;;
    linux)
        libmo="$cgo_dir/libmo.so"
        libusearch="$lib_dir/libusearch_c.so"
        runtime_path_var=LD_LIBRARY_PATH
        platform_link_flags=-fopenmp
        ;;
    *)
        echo "unsupported GOOS for MatrixOne CGo tests: $goos" >&2
        exit 1
        ;;
esac

for required in "$libmo" "$libusearch" "$include_dir"; do
    if [ ! -e "$required" ]; then
        echo "missing MatrixOne CGo prerequisite: $required" >&2
        echo "build the repository thirdparties and CGo libraries before testing" >&2
        exit 1
    fi
done

# Match the repository build contract and remove ambient module/CGo flag
# drift. CC/CXX and other standard toolchain selectors remain caller-owned.
export GOWORK=off
export CGO_CFLAGS="'-I$cgo_dir' '-I$include_dir'"
export CGO_LDFLAGS="'-L$lib_dir'"

runtime_paths="$cgo_dir:$lib_dir"
if [ "$runtime_path_var" = DYLD_LIBRARY_PATH ]; then
    export DYLD_LIBRARY_PATH="$runtime_paths"
else
    export LD_LIBRARY_PATH="$runtime_paths"
fi

# go test executables run from temporary build directories. Use repository
# absolute rpaths; package-relative rpaths belong to distributable binaries.
external_flags="$platform_link_flags -L$cgo_dir -lmo -L$lib_dir -Wl,-rpath,$cgo_dir -Wl,-rpath,$lib_dir"
ldflags="-extldflags '$external_flags'"

cd "$repo_root"
exec go test -mod=readonly -ldflags "$ldflags" "$@"
