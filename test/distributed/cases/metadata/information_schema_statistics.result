drop account if exists stat_view_acc;
drop database if exists stat_view_db;
create database stat_view_db;
use stat_view_db;
create table t (
a int primary key,
b int,
c int,
unique key uniq_b (b),
key idx_bc (b, c)
);
select table_schema, table_name, index_name, column_name, seq_in_index, non_unique
from information_schema.statistics
where table_schema = 'stat_view_db'
and table_name = 't'
order by index_name, seq_in_index;
table_schema    table_name    index_name    column_name    seq_in_index    non_unique
stat_view_db    t    PRIMARY    a    1    0
stat_view_db    t    idx_bc    b    1    1
stat_view_db    t    idx_bc    c    2    1
stat_view_db    t    uniq_b    b    1    0
select count(*) from information_schema.statistics
where table_schema = 'stat_view_db'
and table_name = 't';
count(*)
4
show index from t;
