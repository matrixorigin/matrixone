create table f(a int, v vecf16(3));
insert into f values (1,'[1,2,3]'),(2,'[4,5,6]'),(3,'[1,2,3]');
select a, v = cast('[1,2,3]' as vecf16(3)) as eq, v < cast('[4,5,6]' as vecf16(3)) as lt from f order by a;
