drop database if exists vecnarrowdb;
create database vecnarrowdb;
use vecnarrowdb;
drop table if exists nvec;
create table nvec(a int, bf vecbf16(3), f16 vecf16(3), i8 vecint8(3));
desc nvec;
Field    Type    Null    Key    Default    Extra    Comment
a    INT(32)    YES        null        
bf    VECBF16(3)    YES        null        
f16    VECF16(3)    YES        null        
i8    VECINT8(3)    YES        null        
show create table nvec;
Table    Create Table
nvec    CREATE TABLE `nvec` (\n  `a` int DEFAULT NULL,\n  `bf` vecbf16(3) DEFAULT NULL,\n  `f16` vecf16(3) DEFAULT NULL,\n  `i8` vecint8(3) DEFAULT NULL\n)
insert into nvec values(1, "[1,2,3]", "[1,2,3]", "[1,2,3]");
insert into nvec values(2, "[4,5,6]", "[4,5,6]", "[4,5,6]");
select * from nvec;
a    bf    f16    i8
1    [1, 2, 3]    [1, 2, 3]    [1, 2, 3]
2    [4, 5, 6]    [4, 5, 6]    [4, 5, 6]
drop table if exists i8t;
