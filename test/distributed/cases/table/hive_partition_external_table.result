drop table if exists hive_err8;
create external table hive_err8 (
id int,
emb vecf32(3)
) infile{'filepath'='$resources/hive_partition/single_level/', 'format'='parquet', 'hive_partitioning'='true', 'hive_partition_columns'='emb'};
