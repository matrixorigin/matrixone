select
if(grouping(year), 'All', cast(year as char)) AS year_str,
if(grouping(quarter), 'Total', quarter) as quarter_val,
count(*) as cnt
from
sales_mixed_types
group by
year,
quarter with rollup
order by year_str, quarter_val;
