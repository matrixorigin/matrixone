select
if(grouping(year), 'Total', cast(year as char)) as year,
if(grouping(quarter), 'Total', cast(quarter as char)) as quarter,
if(grouping(region), 'Total', region) as region,
sum(amount) as total_sales
from
sales
group by
year,
quarter,
region with rollup;
