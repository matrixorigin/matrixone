2  ¦  POINT(10 20)  ¦  4326  ¦  POINT(-87.63 41.88)
drop table if exists bad_geo;
create table bad_geo (
id int,
pt point
);
load data inline format='csv', data='1,"LINESTRING(0 0,1 1)"\n' into table bad_geo fields terminated by ',' enclosed by '"';
internal error: the input value 'LINESTRING(0 0,1 1)' is not a valid geometry for column 1: invalid input: cannot store LINESTRING in POINT column
