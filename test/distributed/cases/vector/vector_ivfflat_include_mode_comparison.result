        Limit: 3  𝄀
        ->  Table Function on ivf_search  𝄀
              Index Reader Param:  Limit: 3  𝄀
              Limit: 3  𝄀
              Filter Cond: (`__mo_index_include_category` >= 20)
explain select id, title, category
from phase9_main
where category >= 20
order by l2_distance(embedding, "[1,2,3]")
limit 3 by rank with option 'mode=post';
