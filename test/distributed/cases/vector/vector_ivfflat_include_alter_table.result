drop table if exists vector_ivfflat_include_phase7_plain;
create table vector_ivfflat_include_phase7_plain(
id int primary key,
embedding vecf32(3),
note varchar(20)
);
create index idx_ivf_plain_phase7 using ivfflat on vector_ivfflat_include_phase7_plain(embedding)
lists=2 op_type "vector_l2_ops";
insert into vector_ivfflat_include_phase7_plain values
(1, "[1,2,3]", "n1"),
(2, "[1,2,4]", "n2"),
(3, "[9,9,9]", "n3"),
(4, "[2,2,2]", "n4");
explain select id, note
from vector_ivfflat_include_phase7_plain
where note in ("n2", "n4")
order by l2_distance(embedding, "[1,2,3]")
limit 2 by rank with option 'mode=post';
AP QUERY PLAN ON ONE CN(10 core)
Project
  ->  Sort
        Sort Key: mo_ivf_alias_0.score INTERNAL
        Limit: 2
        ->  Join
              Join Type: INNER
              Join Cond: (vector_ivfflat_include_phase7_plain.id = mo_ivf_alias_0.pkid)
              ->  Table Scan on vector_ivfflat_include_phase7.vector_ivfflat_include_phase7_plain
                    Filter Cond: vector_ivfflat_include_phase7_plain.note in ([n2 n4])
              ->  Table Function on ivf_search
                    Index Reader Param:  Limit: 12
                    Limit: 12
select id, note
from vector_ivfflat_include_phase7_plain
where note in ("n2", "n4")
order by l2_distance(embedding, "[1,2,3]")
limit 2 by rank with option 'mode=post';
id    note
2    n2
4    n4
drop table vector_ivfflat_include_phase7_plain;
