3  ¬¶  61000000  ¬¶  61000000
select id,
vb = binary 'a' as vb_eq_bin_a,
binary 'a' = vb as bin_a_eq_vb,
b = vb as b_eq_vb,
vb = b as vb_eq_b,
b = x'61' as b_eq_short_hex,
b = x'61000000' as b_eq_padded_hex,
vb <=> binary 'a' as vb_null_safe_eq_bin_a,
vb > binary 'a' as vb_gt_bin_a
from t_varbinary_binary_cmp
order by id;
