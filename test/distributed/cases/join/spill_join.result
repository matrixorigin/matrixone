drop table if exists spill_t1;
drop table if exists spill_t2;
create table spill_t1 (
id int primary key,
name varchar(100),
value int
);
create table spill_t2 (
id int primary key,
t1_id int,
category varchar(50)
);
insert into spill_t1 select result, concat('name_', result), result * 10 from generate_series(1, 1000) g;
insert into spill_t2 select result, (result % 1000) + 1, concat('cat_', result % 5) from generate_series(1, 1000) g;
set @@join_spill_mem = 1048576;
select count(*) from spill_t1 inner join spill_t2 on spill_t1.id = spill_t2.t1_id;
count(*)
1000
select count(*) from spill_t1 left join spill_t2 on spill_t1.id = spill_t2.t1_id;
count(*)
1000
select spill_t2.category, count(*) as cnt
from spill_t1
inner join spill_t2 on spill_t1.id = spill_t2.t1_id
group by spill_t2.category
order by spill_t2.category;
category    cnt
cat_0    200
cat_1    200
cat_2    200
cat_3    200
cat_4    200
select count(*)
from spill_t1
inner join spill_t2 on spill_t1.id = spill_t2.t1_id
where spill_t1.value > 1000 and spill_t1.value < 5000;
count(*)
399
select spill_t1.id, spill_t1.name, spill_t2.category
from spill_t1
inner join spill_t2 on spill_t1.id = spill_t2.t1_id
where spill_t1.id <= 5
order by spill_t1.id;
id    name    category
1    name_1    cat_1
2    name_2    cat_2
3    name_3    cat_3
4    name_4    cat_4
5    name_5    cat_0
set @@join_spill_mem = 0;
select count(*) from spill_t1 inner join spill_t2 on spill_t1.id = spill_t2.t1_id;
count(*)
1000
set @@join_spill_mem = 65536;
select count(*)
from spill_t1
inner join spill_t2 on spill_t1.id = spill_t2.t1_id
where spill_t1.id between 100 and 200;
count(*)
101
set @@join_spill_mem = 1048576;
select count(*)
from spill_t1
inner join (
select t1_id, count(*) as cnt
from spill_t2
group by t1_id
) sub on spill_t1.id = sub.t1_id
where sub.cnt > 0;
count(*)
1000
drop table spill_t1;
drop table spill_t2;
set @@join_spill_mem = 0;
