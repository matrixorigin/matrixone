SELECT tA.id AS a_id, tB.id AS b_id, tC.id AS c_id
FROM tA INNER JOIN tB ON tA.id = tB.id
FULL OUTER JOIN tC ON tB.id = tC.id
ORDER BY a_id, b_id, c_id;
