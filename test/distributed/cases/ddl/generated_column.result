create table t4 (x int, y int, z int as (x - y) stored);
show create table t4;
Table    Create Table
t4    CREATE TABLE `t4` (\n  `x` int DEFAULT NULL,\n  `y` int DEFAULT NULL,\n  `z` int GENERATED ALWAYS AS ((x - y)) STORED\n)
