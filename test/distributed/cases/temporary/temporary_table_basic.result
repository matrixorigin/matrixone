drop table temp_select;
create temporary table temp_agg (
id int,
category varchar(50),
amount decimal(10,2)
);
insert into temp_agg values
(1, 'food', 50.00),
(2, 'transport', 30.00),
(3, 'food', 70.00),
(4, 'entertainment', 100.00),
(5, 'transport', 25.00);
select count(*) from temp_agg;
➤ count(*)[-5,64,0]  𝄀
5
select sum(amount) from temp_agg;
➤ sum(amount)[3,38,2]  𝄀
275.00
select avg(amount) from temp_agg;
➤ avg(amount)[3,38,8]  𝄀
55.00000000
select min(amount), max(amount) from temp_agg;
➤ min(amount)[3,10,2]  ¦  max(amount)[3,10,2]  𝄀
25.00  ¦  100.00
select
category,
count(*) as count,
sum(amount) as total,
avg(amount) as average
from temp_agg
group by category;
➤ category[12,-1,0]  ¦  count[-5,64,0]  ¦  total[3,38,2]  ¦  average[3,38,8]  𝄀
food  ¦  2  ¦  120.00  ¦  60.00000000  𝄀
transport  ¦  2  ¦  55.00  ¦  27.50000000  𝄀
entertainment  ¦  1  ¦  100.00  ¦  100.00000000
select
category,
sum(amount) as total
from temp_agg
group by category
having sum(amount) > 50;
➤ category[12,-1,0]  ¦  total[3,38,2]  𝄀
food  ¦  120.00  𝄀
transport  ¦  55.00  𝄀
entertainment  ¦  100.00
drop table temp_agg;
create temporary table temp_subquery (
id int,
product varchar(50),
price decimal(10,2)
);
insert into temp_subquery values
(1, 'laptop', 999.99),
(2, 'mouse', 29.99),
(3, 'keyboard', 79.99),
(4, 'monitor', 299.99),
(5, 'headset', 59.99);
select * from temp_subquery
where price > (select avg(price) from temp_subquery);
➤ id[4,32,0]  ¦  product[12,-1,0]  ¦  price[3,10,2]  𝄀
1  ¦  laptop  ¦  999.99  𝄀
4  ¦  monitor  ¦  299.99
select
count(*) as total_products,
avg(avg_price) as overall_avg
from (
select avg(price) as avg_price from temp_subquery
) sub;
➤ total_products[-5,64,0]  ¦  overall_avg[3,38,12]  𝄀
1  ¦  293.990000000000
select * from temp_subquery
where price in (
select price from temp_subquery where price < 100
);
➤ id[4,32,0]  ¦  product[12,-1,0]  ¦  price[3,10,2]  𝄀
2  ¦  mouse  ¦  29.99  𝄀
3  ¦  keyboard  ¦  79.99  𝄀
5  ¦  headset  ¦  59.99
drop table temp_subquery;
