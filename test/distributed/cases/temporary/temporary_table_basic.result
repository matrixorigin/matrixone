4  ¦  entertainment  ¦  100.00  𝄀
3  ¦  food  ¦  70.00  𝄀
1  ¦  food  ¦  50.00  𝄀
2  ¦  transport  ¦  30.00  𝄀
5  ¦  transport  ¦  25.00
select * from temp_select order by id limit 3;
