-- @suite

-- @case
-- @desc:test for replace data
-- @label:bvt
drop table if exists names;
create table names(id int PRIMARY KEY,name VARCHAR(255),age int);
replace into names(id, name, age) values(1,"Abby", 24);
select name, age from names where id = 1;
replace into names(id, name, age) values(1,"Bobby", 25);
select name, age from names where id = 1;
replace into names set id = 2, name = "Ciro";
select name, age from names where id = 2;
replace into names set id = 2, name = "Ciro", age = 17;
select name, age from names where id = 2;
REPLACE INTO names values (2, "Bob", 19);
select name, age from names where id = 2;
/* comment */ replace into names set id = 2, name = "Dylan";
select name, age from names where id = 2;
-- table without keys
drop table if exists t1;
create table t1(a int, b int, c int);
insert into t1 values (1,1,1), (2,2,2), (3,3,3);
replace t1 values (1,2,3), (2,3,4);
select a, b, c from t1;
create table t4 (a int unique key, b varchar(64));
replace into t4 values (1, 'a');
select * from t4;
replace into t4 values (1, 'b');
select * from t4;

drop table if exists t1;
create table t1(a int primary key, b int unique, c varchar(255), key(c));
insert into t1 values (1,1,"1"), (2,2,"2");
select * from t1;
replace into t1 values (1,4,"4"), (3,3,"3");
select * from t1;

create database replace_db;
use replace_db;
replace into `replace`.`names` values (2, "Dylan", 20);
select name, age from `replace`.`names` where id = 2;

drop table if exists c;
create table c(a int primary key , b int, v vecf32(3));
replace into c values(1,1,'[1,2,3]');
select * from c;
drop table c;
drop table if exists c;
create table c(a int primary key , b int, v vecf32(3));
replace into c values(1,1,'[1,2,3]');
drop table if exists f;
create table f (a int primary key, b int, c int, v vecf32(3));
replace into f with c1 as (select * from c), src as (select * from (values row(1,1, cast('[3,4,5]' as vecf32(3))))) select a, column_0, column_1, column_2 from c1,src where c1.a = src.column_0;
drop table f;
drop table c;

create table bug_22340 (a int not null auto_increment, a1 int default null, b vecf64(3) DEFAULT NULL COMMENT 'document向量化信息', PRIMARY KEY (`a`), KEY `idx_vec` USING ivfflat (`b`) lists = 1 op_type 'vector_l2_ops');
REPLACE INTO bug_22340 VALUES (1,100,'[1, 2, 3]'),(2,100,'[1, 2, 3]'),(3,100,'[1, 2, 3]'),(4,100,'[1, 2, 3]'),(5,100,'[1, 2, 3]'),(6,100,'[1, 2, 3]'),(7,100,'[1, 2, 3]'),(8,100,'[1, 2, 3]'),(9,100,'[1, 2, 3]'),(10,100,'[1, 2, 3]');
-- @separator:table
select mo_ctl('dn','flush','replace_db.bug_22340');
REPLACE INTO bug_22340 VALUES (1,100,'[1, 2, 3]'),(2,100,'[1, 2, 3]'),(3,100,'[1, 2, 3]'),(4,100,'[1, 2, 3]'),(5,100,'[1, 2, 3]'),(6,100,'[1, 2, 3]'),(7,100,'[1, 2, 3]'),(8,100,'[1, 2, 3]'),(9,100,'[1, 2, 3]'),(10,100,'[1, 2, 3]');
drop table bug_22340;

drop database replace_db;
use `replace`;

-- test NULL on unique key column: multiple NULLs should not conflict
drop table if exists t_null_uk;
create table t_null_uk(id int primary key, a int, b varchar(64), unique key(a));
replace into t_null_uk values (1, NULL, 'first');
replace into t_null_uk values (2, NULL, 'second');
select id, a, b from t_null_uk order by id;
replace into t_null_uk values (3, 1, 'third');
select id, a, b from t_null_uk order by id;
drop table t_null_uk;

-- test fake PK table with unique key only
drop table if exists t_fake_pk;
create table t_fake_pk(a int unique key, b varchar(64));
replace into t_fake_pk values (1, 'hello');
select * from t_fake_pk;
replace into t_fake_pk values (1, 'world');
select * from t_fake_pk;
replace into t_fake_pk values (2, 'foo');
select * from t_fake_pk order by a;
drop table t_fake_pk;

-- test duplicate source keys within one REPLACE statement
drop table if exists t_replace_dup_pk;
create table t_replace_dup_pk(id int primary key, v int);
replace into t_replace_dup_pk values (1, 10), (1, 20), (2, 30);
select * from t_replace_dup_pk order by id;
drop table t_replace_dup_pk;

drop table if exists t_replace_dup_pk_src;
create table t_replace_dup_pk_src(id int primary key, v int);
drop table if exists s_replace_dup_pk;
create table s_replace_dup_pk(id int, v int);
insert into s_replace_dup_pk values (1, 10), (1, 20), (2, 30);
replace into t_replace_dup_pk_src select * from s_replace_dup_pk order by v;
select * from t_replace_dup_pk_src order by id;
drop table s_replace_dup_pk;
drop table t_replace_dup_pk_src;

drop table if exists t_replace_dup_uk;
create table t_replace_dup_uk(id int primary key, u int unique, v int);
replace into t_replace_dup_uk values (1, 1, 10), (2, 1, 20), (3, 2, 30);
select * from t_replace_dup_uk order by u;
drop table t_replace_dup_uk;

drop table if exists t_replace_dup_pk_existing;
create table t_replace_dup_pk_existing(id int primary key, v int);
insert into t_replace_dup_pk_existing values (1, 5);
replace into t_replace_dup_pk_existing values (1, 10), (1, 20), (2, 30);
select * from t_replace_dup_pk_existing order by id;
drop table t_replace_dup_pk_existing;

drop table if exists t_replace_dup_uk_existing;
create table t_replace_dup_uk_existing(id int primary key, u int unique, v int);
insert into t_replace_dup_uk_existing values (9, 1, 5);
replace into t_replace_dup_uk_existing values (1, 1, 10), (2, 1, 20), (3, 2, 30);
select * from t_replace_dup_uk_existing order by u;
drop table t_replace_dup_uk_existing;

-- test INSERT ON DUPLICATE KEY UPDATE rewrite to REPLACE
drop table if exists t_odku;
create table t_odku(id int primary key, name varchar(64), val int);
insert into t_odku values (1, 'a', 10);
insert into t_odku values (1, 'b', 20) on duplicate key update name = values(name), val = values(val);
select * from t_odku;
drop table t_odku;

-- test PK + UK conflict
drop table if exists t_pk_uk;
create table t_pk_uk(id int primary key, a int unique, b varchar(64));
insert into t_pk_uk values (1, 10, 'first'), (2, 20, 'second');
replace into t_pk_uk values (1, 30, 'updated');
select * from t_pk_uk order by id;
drop table t_pk_uk;

-- test REPLACE on AUTO_INCREMENT table with UNIQUE constraint
-- only the UNIQUE column conflicts; PK is auto-generated
drop table if exists ai_replace_test;
create table ai_replace_test (id int auto_increment primary key, name varchar(50) unique, value int);
insert into ai_replace_test (name, value) values ('key1', 100), ('key2', 200);
replace into ai_replace_test (name, value) values ('key1', 300);
select * from ai_replace_test order by id;
insert into ai_replace_test (name, value) values ('key3', 400);
select * from ai_replace_test order by id;
drop table ai_replace_test;

-- test REPLACE on AUTO_INCREMENT table with composite UNIQUE key
-- Distractor row (1, 2) shares the first key part with (1, 1) but must NOT be
-- deleted when REPLACE targets (1, 1). This ensures the planner matches on
-- ALL composite-key parts, not just the first one.
drop table if exists ai_composite_uk;
create table ai_composite_uk (id int auto_increment primary key, a int, b int, value int, unique key uk_ab(a, b));
insert into ai_composite_uk (a, b, value) values (1, 1, 100), (1, 2, 150), (2, 2, 200);
replace into ai_composite_uk (a, b, value) values (1, 1, 300);
select * from ai_composite_uk order by id;
drop table ai_composite_uk;

-- test REPLACE on AUTO_INCREMENT table with multiple UNIQUE indexes
drop table if exists ai_multi_uk;
create table ai_multi_uk (id int auto_increment primary key, name varchar(50) unique, email varchar(100) unique, value int);
insert into ai_multi_uk (name, email, value) values ('n1', 'n1@a.com', 100), ('n2', 'n2@a.com', 200);
replace into ai_multi_uk (name, email, value) values ('n1', 'n1_new@a.com', 300);
select * from ai_multi_uk order by id;
replace into ai_multi_uk (name, email, value) values ('n_new', 'n2@a.com', 400);
select * from ai_multi_uk order by id;
drop table ai_multi_uk;

-- test cross-key REPLACE keeps old-row delete side effects
drop table if exists t_replace_cross_key_keep_last;
create table t_replace_cross_key_keep_last(id int primary key, u int unique, v int);
insert into t_replace_cross_key_keep_last values (1, 100, 0);
replace into t_replace_cross_key_keep_last values (1, 200, 10), (2, 200, 20);
select * from t_replace_cross_key_keep_last order by id;
drop table t_replace_cross_key_keep_last;

-- test REPLACE NULL-PK filtering uses the actual primary key column
drop table if exists t_replace_pk_not_first;
create table t_replace_pk_not_first(a int null, id int primary key, u int unique);
insert into t_replace_pk_not_first values (0, 1, 100);
replace into t_replace_pk_not_first values (null, 1, 200), (null, 2, 200);
select * from t_replace_pk_not_first order by id;
drop table t_replace_pk_not_first;

-- test REPLACE rechecks NOT NULL after filtering delete-only rows
drop table if exists t_replace_not_null_after_filter;
create table t_replace_not_null_after_filter(a int null, id int primary key, u int unique, b int not null);
insert into t_replace_not_null_after_filter values (0, 1, 100, 1);
replace into t_replace_not_null_after_filter values (null, 1, 200, 10), (5, 2, 200, null);
select * from t_replace_not_null_after_filter order by id;
drop table t_replace_not_null_after_filter;

-- one new row conflicts with different old rows via different unique keys:
-- delete every matched old row and insert the new row exactly once
drop table if exists t_replace_multi_uk_fanout;
create table t_replace_multi_uk_fanout (id int auto_increment primary key, name varchar(50) unique, email varchar(100) unique, value int);
insert into t_replace_multi_uk_fanout (name, email, value) values ('a', 'x@a.com', 100), ('b', 'y@a.com', 200);
replace into t_replace_multi_uk_fanout (name, email, value) values ('a', 'y@a.com', 300);
select name, email, value from t_replace_multi_uk_fanout order by name;
drop table t_replace_multi_uk_fanout;

-- new row's explicit primary key matches one old row while two unique keys
-- match two other old rows (three-way fan-out)
drop table if exists t_replace_pk_and_uk_fanout;
create table t_replace_pk_and_uk_fanout (id int primary key, name varchar(50) unique, email varchar(100) unique, value int);
insert into t_replace_pk_and_uk_fanout values (1, 'a', 'x@a.com', 100), (2, 'b', 'y@a.com', 200), (3, 'c', 'z@a.com', 300);
replace into t_replace_pk_and_uk_fanout values (1, 'b', 'z@a.com', 999);
select * from t_replace_pk_and_uk_fanout order by id;
drop table t_replace_pk_and_uk_fanout;

-- fake-PK table (no real primary key) with multiple unique keys: a new row
-- conflicting on different unique keys must also delete all matched old rows
drop table if exists t_replace_fakepk_multi_uk;
create table t_replace_fakepk_multi_uk (a varchar(50) unique, b varchar(100) unique, v int);
insert into t_replace_fakepk_multi_uk values ('a', 'x', 100), ('b', 'y', 200);
replace into t_replace_fakepk_multi_uk values ('a', 'y', 300);
select * from t_replace_fakepk_multi_uk order by a;
drop table t_replace_fakepk_multi_uk;

-- composite unique key fan-out
drop table if exists t_replace_composite_uk_fanout;
create table t_replace_composite_uk_fanout (id int primary key, a int, b int, v int, unique key uk(a, b));
insert into t_replace_composite_uk_fanout values (1, 10, 20, 100), (2, 30, 40, 200);
replace into t_replace_composite_uk_fanout values (3, 10, 20, 999);
select * from t_replace_composite_uk_fanout order by id;
drop table t_replace_composite_uk_fanout;

-- multi-row REPLACE batch where each row independently fans out
drop table if exists t_replace_multi_uk_batch;
create table t_replace_multi_uk_batch (id int auto_increment primary key, name varchar(50) unique, email varchar(100) unique, value int);
insert into t_replace_multi_uk_batch (name, email, value) values ('a', 'x@a.com', 100), ('b', 'y@a.com', 200), ('c', 'z@a.com', 300);
replace into t_replace_multi_uk_batch (name, email, value) values ('a', 'y@a.com', 111), ('b', 'z@a.com', 222);
select name, email, value from t_replace_multi_uk_batch order by name;
drop table t_replace_multi_uk_batch;
-- child-side foreign key check during REPLACE: an inserted/replaced child row
-- must reference an existing parent row, otherwise REPLACE fails and the
-- previous conflicting row stays intact
drop table if exists replace_fk_c;
drop table if exists replace_fk_p;
create table replace_fk_p(id int primary key);
create table replace_fk_c(id int primary key, pid int, foreign key(pid) references replace_fk_p(id));
insert into replace_fk_p values (1);
replace into replace_fk_c values (10,1);
select * from replace_fk_c order by id;
-- replacing an existing child row to reference a missing parent must fail
replace into replace_fk_c values (10,2);
select * from replace_fk_c order by id;
-- inserting a new child row referencing a missing parent must fail
replace into replace_fk_c values (11,99);
select * from replace_fk_c order by id;
-- NULL foreign key value is allowed and needs no parent row
replace into replace_fk_c values (12,null);
select * from replace_fk_c order by id;
-- a valid replace referencing an existing parent succeeds and replaces the old row
insert into replace_fk_p values (2);
replace into replace_fk_c values (10,2);
select * from replace_fk_c order by id;
drop table replace_fk_c;
drop table replace_fk_p;

-- REPLACE ... SET evaluates an RHS column reference as DEFAULT(col), and
-- omitted columns fall back to their defaults (MySQL-compatible).
drop table if exists t_set_default;
create table t_set_default(id int primary key, v int default 5, note varchar(20) default 'd');
insert into t_set_default values (1, 10, 'old');
replace into t_set_default set id = 1, v = v + 1;
select * from t_set_default order by id;
replace into t_set_default set id = 2, v = v * 2;
select * from t_set_default order by id;
drop table t_set_default;

-- RHS references another column, also resolved to that column's DEFAULT value
drop table if exists t_set_default2;
create table t_set_default2(id int primary key, a int default 3, b int default 7);
insert into t_set_default2 values (1, 100, 200);
replace into t_set_default2 set id = 1, a = b + 1;
select * from t_set_default2 order by id;
drop table t_set_default2;

-- RHS column reference inside a function expression is also resolved to DEFAULT(col)
drop table if exists t_set_func;
create table t_set_func(id int primary key, dname varchar(50) default 'hello', suffix varchar(20) default '_mo');
insert into t_set_func values (1, 'world', '_x');
replace into t_set_func set id = 1, dname = upper(dname);
select * from t_set_func order by id;
replace into t_set_func set id = 2, dname = concat(dname, '_mo');
select * from t_set_func order by id;
replace into t_set_func set id = 3, dname = concat(upper(dname), suffix);
select * from t_set_func order by id;
drop table t_set_func;

-- MySQL-compatible REPLACE syntax variants: TABLE source (with/without column list), LOW_PRIORITY, DELAYED
drop table if exists t_replace_src;
drop table if exists t_replace_dst;
create table t_replace_src (id int primary key, v int);
create table t_replace_dst (id int primary key, v int);
insert into t_replace_src values (1, 10), (2, 20), (3, 30);
insert into t_replace_dst values (1, 999);
replace into t_replace_dst table t_replace_src;
select * from t_replace_dst order by id;
replace into t_replace_dst (id, v) table t_replace_src;
select * from t_replace_dst order by id;
truncate table t_replace_dst;
replace into t_replace_dst table t_replace_src order by id desc limit 1;
select * from t_replace_dst order by id;
replace into t_replace_dst (id, v) table t_replace_src order by id limit 1 offset 1;
select * from t_replace_dst order by id;
drop table t_replace_src;
drop table t_replace_dst;
drop table if exists t_replace_prio;
create table t_replace_prio (id int primary key, v int);
replace low_priority into t_replace_prio values (1, 20);
replace delayed into t_replace_prio values (1, 30);
select * from t_replace_prio order by id;
drop table t_replace_prio;

-- test REPLACE validates CHECK constraints before deleting the old row
drop table if exists t_replace_check;
create table t_replace_check(id int primary key, v int check (v > 0));
insert into t_replace_check values (1, 10);
replace into t_replace_check values (1, -1);
select * from t_replace_check order by id;
replace into t_replace_check values (2, null);
select * from t_replace_check order by id;
insert into t_replace_check values (3, -3);
select * from t_replace_check order by id;
insert into t_replace_check values (3, 30), (4, -4);
select * from t_replace_check order by id;
insert into t_replace_check values (1, -5) on duplicate key update v = values(v);
select * from t_replace_check order by id;
update t_replace_check set v = -3 where id = 1;
select * from t_replace_check order by id;
drop table t_replace_check;

drop table if exists t_replace_table_check;
create table t_replace_table_check(id int primary key, a int, b int, check (a < b));
insert into t_replace_table_check values (1, 1, 2);
insert into t_replace_table_check values (2, 3, 2);
select * from t_replace_table_check order by id;
drop table t_replace_table_check;

drop table if exists t_insert_check_no_key;
create table t_insert_check_no_key(a int check (a > 0), b int);
insert into t_insert_check_no_key values (-1, 2) on duplicate key update b = values(b);
select * from t_insert_check_no_key order by a;
insert into t_insert_check_no_key values (1, 2) on duplicate key update b = values(b);
select * from t_insert_check_no_key order by a;
drop table t_insert_check_no_key;

-- a column-level CHECK may reference only the column where it is defined
drop table if exists t_column_check_cross;
create table t_column_check_cross(id int primary key, a int, b int check (a < b));
create table t_column_check_cross(id int primary key, a int, b int);
insert into t_column_check_cross values (1, -1, 0);
select * from t_column_check_cross;
drop table t_column_check_cross;

-- truthiness: numeric CHECK (a) — 1 passes, 0 fails, null passes
drop table if exists t_chk_truth;
create table t_chk_truth(a int, check (a));
insert into t_chk_truth values (1);
insert into t_chk_truth values (null);
select * from t_chk_truth order by a;
drop table t_chk_truth;

-- truthiness: zero should fail
drop table if exists t_chk_fail;
create table t_chk_fail(a int, check (a));
insert into t_chk_fail values (0);
select * from t_chk_fail;
drop table t_chk_fail;

-- UPDATE must enforce CHECK
drop table if exists t_chk_update;
create table t_chk_update(a int, check (a > 0));
insert into t_chk_update values (1);
update t_chk_update set a = a + 1;
select * from t_chk_update;
drop table t_chk_update;

-- UPDATE violates CHECK
drop table if exists t_chk_update_fail;
create table t_chk_update_fail(a int, check (a > 0));
insert into t_chk_update_fail values (1);
update t_chk_update_fail set a = -1;
select * from t_chk_update_fail;
drop table t_chk_update_fail;

-- UPDATE IGNORE skips CHECK violations while applying valid row updates
drop table if exists t_chk_update_ignore;
create table t_chk_update_ignore(id int primary key, a int, check (a > 0));
insert into t_chk_update_ignore values (1, 1), (2, 2);
update ignore t_chk_update_ignore
set a = case when id = 1 then -1 else 3 end;
select * from t_chk_update_ignore order by id;
drop table t_chk_update_ignore;

-- legacy multi-table UPDATE fallback must enforce CHECK on the final row image
drop table if exists t_chk_update_multi;
drop table if exists t_chk_update_multi_src;
create table t_chk_update_multi(id int primary key, a int, check (a > 0));
create table t_chk_update_multi_src(id int primary key);
insert into t_chk_update_multi values (1, 1);
insert into t_chk_update_multi_src values (1);
update t_chk_update_multi, t_chk_update_multi_src
set t_chk_update_multi.a = -1
where t_chk_update_multi.id = t_chk_update_multi_src.id;
select * from t_chk_update_multi;
drop table t_chk_update_multi;
drop table t_chk_update_multi_src;

-- legacy multi-table UPDATE IGNORE also skips only CHECK-violating rows
drop table if exists t_chk_update_multi_ignore;
drop table if exists t_chk_update_multi_ignore_src;
create table t_chk_update_multi_ignore(id int primary key, a int, check (a > 0));
create table t_chk_update_multi_ignore_src(id int primary key);
insert into t_chk_update_multi_ignore values (1, 1), (2, 2);
insert into t_chk_update_multi_ignore_src values (1), (2);
update ignore t_chk_update_multi_ignore, t_chk_update_multi_ignore_src
set t_chk_update_multi_ignore.a = case when t_chk_update_multi_ignore.id = 1 then -1 else 3 end
where t_chk_update_multi_ignore.id = t_chk_update_multi_ignore_src.id;
select * from t_chk_update_multi_ignore order by id;
drop table t_chk_update_multi_ignore;
drop table t_chk_update_multi_ignore_src;

-- REPLACE must enforce CHECK
drop table if exists t_chk_replace;
create table t_chk_replace(id int primary key, a int, check (a > 0));
replace into t_chk_replace values (1, 1);
select * from t_chk_replace;
drop table t_chk_replace;

-- REPLACE violates CHECK
drop table if exists t_chk_replace_fail;
create table t_chk_replace_fail(id int primary key, a int, check (a > 0));
replace into t_chk_replace_fail values (1, -1);
select * from t_chk_replace_fail;
drop table t_chk_replace_fail;

-- duplicate check constraint name should fail at DDL
drop table if exists t_chk_dup_name;
create table t_chk_dup_name(
    a int,
    constraint chk_pos check (a > 0),
    constraint chk_pos check (a < 10)
);
drop table if exists t_chk_dup_name;

-- non-deterministic function should be rejected in CHECK
drop table if exists t_chk_volatile;
create table t_chk_volatile(a int, check (rand() > 0));
drop table if exists t_chk_volatile;

-- fake-PK table with a composite nullable unique key: a REPLACE whose composite
-- unique-key part is statically NULL (column a omitted -> NULL) serializes to a NULL
-- key, can never conflict, and behaves like a plain INSERT (no existing row deleted;
-- a NULL key is allowed multiple times). A fully non-NULL key still conflicts and replaces.
drop table if exists t_replace_fakepk_comp_null;
create table t_replace_fakepk_comp_null (a int, b int, c varchar(20), unique key uk_ab(a, b));
insert into t_replace_fakepk_comp_null values (1, 1, 'one'), (2, 2, 'two');
replace into t_replace_fakepk_comp_null (b, c) values (1, 'null-a');
select a, b, c from t_replace_fakepk_comp_null order by a, b, c;
replace into t_replace_fakepk_comp_null (b, c) values (1, 'null-a-2');
select a, b, c from t_replace_fakepk_comp_null order by a, b, c;
replace into t_replace_fakepk_comp_null (a, b, c) values (1, 1, 'one-replaced');
select a, b, c from t_replace_fakepk_comp_null order by a, b, c;
drop table t_replace_fakepk_comp_null;

-- SHOW CREATE TABLE must still render CHECK after the table round-trips through
-- the engine (the deep copy of TableDef must preserve each check's OriginSql).
drop table if exists t_chk_showcreate;
create table t_chk_showcreate(id int primary key, v int, constraint chk_v check (v > 0));
show create table t_chk_showcreate;
drop table t_chk_showcreate;

-- CREATE TABLE ... AS SELECT: an explicit column that shares its name with a
-- SELECT output column must still carry its column-level CHECK.
drop table if exists t_ctas_chk;
create table t_ctas_chk(a int check (a > 0)) as select -1 as a;
drop table if exists t_ctas_chk;
create table t_ctas_chk(a int check (a > 0)) as select 1 as a;
insert into t_ctas_chk values (-5);
select * from t_ctas_chk order by a;
drop table t_ctas_chk;

-- INSERT IGNORE must skip check-violating rows and insert the rest, not abort.
drop table if exists t_chk_ignore;
create table t_chk_ignore(a int check (a > 0));
insert ignore into t_chk_ignore values (-1), (1), (-2), (2);
show warnings;
select * from t_chk_ignore order by a;
show warnings;
drop table t_chk_ignore;

-- legacy LOAD DATA fallback on an FK table keeps IGNORE CHECK semantics.
drop table if exists t_chk_load_child;
drop table if exists t_chk_load_parent;
create table t_chk_load_parent(id int primary key);
create table t_chk_load_child(
    id int primary key,
    parent_id int,
    check (id > 0),
    foreign key (parent_id) references t_chk_load_parent(id)
);
insert into t_chk_load_parent values (1);
load data inline format='csv', data='-1,1\n1,1\n' ignore
into table t_chk_load_child fields terminated by ',';
show warnings;
select * from t_chk_load_child order by id;
drop table t_chk_load_child;
drop table t_chk_load_parent;

-- INSERT IGNORE evaluates CHECK per row before the unique-key dedup: an invalid
-- row sharing a primary key with a later valid row must not mask it. Expect (1,1).
drop table if exists t_chk_ignore_dedup;
create table t_chk_ignore_dedup(id int primary key, v int check (v > 0));
insert ignore into t_chk_ignore_dedup values (1, -1), (1, 1);
select * from t_chk_ignore_dedup order by id;
drop table t_chk_ignore_dedup;

-- ALTER TABLE ADD COLUMN with a column-level CHECK that references the new column.
drop table if exists t_chk_addcol;
create table t_chk_addcol(id int primary key);
alter table t_chk_addcol add column b int check (b > 0);
insert into t_chk_addcol values (1, 5);
insert into t_chk_addcol values (2, -5);
select * from t_chk_addcol order by id;
drop table t_chk_addcol;

-- ALTER column-level CHECK may reference only the newly added column.
drop table if exists t_chk_addcol_cross;
create table t_chk_addcol_cross(id int primary key, a int);
alter table t_chk_addcol_cross add column b int check (a < b);
insert into t_chk_addcol_cross values (1, -1);
select * from t_chk_addcol_cross;
drop table t_chk_addcol_cross;

-- ALTER ADD COLUMN with NOT ENFORCED must retain the constraint as schema
-- metadata without rejecting rows that violate it.
drop table if exists t_chk_addcol_notenforced;
create table t_chk_addcol_notenforced(id int primary key);
alter table t_chk_addcol_notenforced add column b int check (b > 0) not enforced;
insert into t_chk_addcol_notenforced values (1, -5);
show create table t_chk_addcol_notenforced;
select * from t_chk_addcol_notenforced order by id;
drop table t_chk_addcol_notenforced;

-- Renaming a column that a CHECK depends on must be rejected; renaming an
-- unrelated column is still allowed.
drop table if exists t_chk_rename;
create table t_chk_rename(a int, b int, check (a > 0));
alter table t_chk_rename rename column a to a2;
alter table t_chk_rename rename column b to b2;
drop table t_chk_rename;

-- CHECK recovery uses the creation SQL mode after the session mode changes.
drop table if exists t_chk_sql_mode;
set @old_sql_mode = @@sql_mode;
set sql_mode = 'ANSI_QUOTES';
create table t_chk_sql_mode(a int, check ("a" > 0));
set sql_mode = '';
insert into t_chk_sql_mode values (-1);
insert into t_chk_sql_mode values (1);
select * from t_chk_sql_mode;
drop table t_chk_sql_mode;
set sql_mode = @old_sql_mode;

-- RENAME TABLE rewrites generated-prefix and matching explicit CHECK names.
drop table if exists t_chk_rename_name_new;
drop table if exists t_chk_rename_name;
create table t_chk_rename_name(
    a int,
    constraint t_chk_rename_name_chk_custom check (a > 0),
    check (a < 10)
);
rename table t_chk_rename_name to t_chk_rename_name_new;
show create table t_chk_rename_name_new;
drop table t_chk_rename_name_new;
