drop table if exists names;
create table names(id int PRIMARY KEY,name VARCHAR(255),age int);
replace into names(id, name, age) values(1,"Abby", 24);
select name, age from names where id = 1;
name    age
Abby    24
replace into names(id, name, age) values(1,"Bobby", 25);
select name, age from names where id = 1;
name    age
Bobby    25
replace into names set id = 2, name = "Ciro";
select name, age from names where id = 2;
name    age
Ciro    null
replace into names set id = 2, name = "Ciro", age = 17;
select name, age from names where id = 2;
name    age
Ciro    17
REPLACE INTO names values (2, "Bob", 19);
select name, age from names where id = 2;
name    age
Bob    19
/* comment */ replace into names set id = 2, name = "Dylan";
select name, age from names where id = 2;
name    age
Dylan    null
drop table if exists t1;
create table t1(a int, b int, c int);
insert into t1 values (1,1,1), (2,2,2), (3,3,3);
replace t1 values (1,2,3), (2,3,4);
select a, b, c from t1;
a    b    c
1    2    3
1    2    3
1    2    3
2    3    4
2    3    4
2    3    4
create table t4 (a int unique key, b varchar(64));
replace into t4 values (1, 'a');
select * from t4;
a    b
1    a
replace into t4 values (1, 'b');
select * from t4;
a    b
1    b
drop table if exists t1;
create table t1(a int primary key, b int unique, c varchar(255), key(c));
insert into t1 values (1,1,"1"), (2,2,"2");
select * from t1;
a    b    c
1    1    1
2    2    2
replace into t1 values (1,4,"4"), (3,3,"3");
select * from t1;
a    b    c
2    2    2
1    4    4
3    3    3
create database replace_db;
use replace_db;
replace into `replace`.`names` values (2, "Dylan", 20);
select name, age from `replace`.`names` where id = 2;
name    age
Dylan    20
drop table if exists c;
create table c(a int primary key , b int, v vecf32(3));
replace into c values(1,1,'[1,2,3]');
select * from c;
a    b    v
1    1    [1, 2, 3]
drop table c;
drop table if exists c;
create table c(a int primary key , b int, v vecf32(3));
replace into c values(1,1,'[1,2,3]');
drop table if exists f;
create table f (a int primary key, b int, c int, v vecf32(3));
replace into f with c1 as (select * from c), src as (select * from (values row(1,1, cast('[3,4,5]' as vecf32(3))))) select a, column_0, column_1, column_2 from c1,src where c1.a = src.column_0;
drop table f;
drop table c;
create table bug_22340 (a int not null auto_increment, a1 int default null, b vecf64(3) DEFAULT NULL COMMENT 'document向量化信息', PRIMARY KEY (`a`), KEY `idx_vec` USING ivfflat (`b`) lists = 1 op_type 'vector_l2_ops');
REPLACE INTO bug_22340 VALUES (1,100,'[1, 2, 3]'),(2,100,'[1, 2, 3]'),(3,100,'[1, 2, 3]'),(4,100,'[1, 2, 3]'),(5,100,'[1, 2, 3]'),(6,100,'[1, 2, 3]'),(7,100,'[1, 2, 3]'),(8,100,'[1, 2, 3]'),(9,100,'[1, 2, 3]'),(10,100,'[1, 2, 3]');
select mo_ctl('dn','flush','replace_db.bug_22340');
mo_ctl(dn, flush, replace_db.bug_22340)
{\n  "method": "Flush",\n  "result": [\n    {\n      "returnStr": "OK"\n    }\n  ]\n}\n
REPLACE INTO bug_22340 VALUES (1,100,'[1, 2, 3]'),(2,100,'[1, 2, 3]'),(3,100,'[1, 2, 3]'),(4,100,'[1, 2, 3]'),(5,100,'[1, 2, 3]'),(6,100,'[1, 2, 3]'),(7,100,'[1, 2, 3]'),(8,100,'[1, 2, 3]'),(9,100,'[1, 2, 3]'),(10,100,'[1, 2, 3]');
drop table bug_22340;
drop database replace_db;
use `replace`;
drop table if exists t_null_uk;
create table t_null_uk(id int primary key, a int, b varchar(64), unique key(a));
replace into t_null_uk values (1, NULL, 'first');
replace into t_null_uk values (2, NULL, 'second');
select id, a, b from t_null_uk order by id;
id    a    b
1    null    first
2    null    second
replace into t_null_uk values (3, 1, 'third');
select id, a, b from t_null_uk order by id;
id    a    b
1    null    first
2    null    second
3    1    third
drop table t_null_uk;
drop table if exists t_fake_pk;
create table t_fake_pk(a int unique key, b varchar(64));
replace into t_fake_pk values (1, 'hello');
select * from t_fake_pk;
a    b
1    hello
replace into t_fake_pk values (1, 'world');
select * from t_fake_pk;
a    b
1    world
replace into t_fake_pk values (2, 'foo');
select * from t_fake_pk order by a;
a    b
1    world
2    foo
drop table t_fake_pk;
drop table if exists t_odku;
create table t_odku(id int primary key, name varchar(64), val int);
insert into t_odku values (1, 'a', 10);
insert into t_odku values (1, 'b', 20) on duplicate key update name = values(name), val = values(val);
select * from t_odku;
id    name    val
1    b    20
drop table t_odku;
drop table if exists t_pk_uk;
create table t_pk_uk(id int primary key, a int unique, b varchar(64));
insert into t_pk_uk values (1, 10, 'first'), (2, 20, 'second');
replace into t_pk_uk values (1, 30, 'updated');
select * from t_pk_uk order by id;
id    a    b
1    30    updated
2    20    second
drop table t_pk_uk;
