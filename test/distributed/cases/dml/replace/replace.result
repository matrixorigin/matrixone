drop database replace_db;
use `replace`;
drop table if exists multi_uk;
create table multi_uk (pk int primary key, uk1 int unique, uk2 int unique, v varchar(10));
insert into multi_uk values (1, 10, 100, 'old1'), (2, 20, 200, 'old2');
replace into multi_uk values (1, 20, 300, 'new');
select * from multi_uk order by pk;
➤ pk[4,32,0]  ¦  uk1[4,32,0]  ¦  uk2[4,32,0]  ¦  v[12,-1,0]  𝄀
1  ¦  20  ¦  300  ¦  new
drop table multi_uk;
drop table if exists multi_uk2;
create table multi_uk2 (pk int primary key, uk1 int unique, v varchar(10));
insert into multi_uk2 values (1, 10, 'a'), (2, 20, 'b'), (3, 30, 'c');
replace into multi_uk2 values (1, 20, 'new');
select * from multi_uk2 order by pk;
➤ pk[4,32,0]  ¦  uk1[4,32,0]  ¦  v[12,-1,0]  𝄀
1  ¦  20  ¦  new  𝄀
3  ¦  30  ¦  c
drop table multi_uk2;
