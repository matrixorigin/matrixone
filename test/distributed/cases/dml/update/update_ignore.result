drop table if exists update_ignore_regression;
create table update_ignore_regression (
id int primary key,
a int unique,
v int
);
insert into update_ignore_regression values (1, 10, 0), (2, 20, 0);
update ignore update_ignore_regression set id = id, v = v + 1 where id = 1;
select * from update_ignore_regression order by id;
id    a    v
1    10    1
2    20    0
update ignore update_ignore_regression set a = a, v = v + 1 where id = 2;
select * from update_ignore_regression order by id;
id    a    v
1    10    1
2    20    1
update ignore update_ignore_regression set id = 2, v = 99 where id = 1;
select * from update_ignore_regression order by id;
id    a    v
1    10    1
2    20    1
drop table update_ignore_regression;
drop table if exists update_ignore_multi_unique;
create table update_ignore_multi_unique (
id int primary key,
u int unique
);
insert into update_ignore_multi_unique values (1, 10), (2, 20), (3, 30);
update ignore update_ignore_multi_unique
set id = case id when 1 then 4 when 3 then 1 else id end,
u = case id when 1 then 20 else u end
where id in (1, 3);
select * from update_ignore_multi_unique order by id;
id    u
1    10
2    20
3    30
drop table update_ignore_multi_unique;
drop table if exists update_ignore_key_swap;
create table update_ignore_key_swap (id int primary key, v int);
insert into update_ignore_key_swap values (1, 10), (2, 20);
update ignore update_ignore_key_swap set id = 3 - id;
select * from update_ignore_key_swap order by id;
id    v
1    10
2    20
drop table update_ignore_key_swap;
drop table if exists update_ignore_owner_wins;
create table update_ignore_owner_wins (id int primary key, v int);
insert into update_ignore_owner_wins values (1, 10), (2, 20);
update ignore update_ignore_owner_wins set id = 2, v = v + 1;
select * from update_ignore_owner_wins order by id;
id    v
1    10
2    21
drop table update_ignore_owner_wins;
drop table if exists update_ignore_nullable_unique;
create table update_ignore_nullable_unique (id int primary key, a int unique, v int);
insert into update_ignore_nullable_unique values (1, null, 0), (2, 20, 0), (3, 10, 0);
update ignore update_ignore_nullable_unique
set a = case id when 2 then 10 else a end,
v = v + 1
where id in (1, 2);
select * from update_ignore_nullable_unique order by id;
id    a    v
1    null    1
2    20    0
3    10    0
drop table update_ignore_nullable_unique;
create table update_ignore_owner_wins (id int primary key, v int);
insert into update_ignore_owner_wins values (1, 10), (2, 20);
update ignore update_ignore_owner_wins set id = 2, v = v + 1 order by id desc;
select * from update_ignore_owner_wins order by id;
id    v
1    10
2    21
drop table update_ignore_owner_wins;
