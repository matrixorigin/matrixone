drop table if exists t1;
create table t1(ts timestamp);
set time_zone = '+00:00';
load data infile '$resources/load_data/timestamp_timezone.csv' into table t1 fields terminated by ',';
select * from t1;
➤ ts[93,64,0]  𝄀
2020-09-07 00:00:00
set time_zone = '+08:00';
select * from t1;
➤ ts[93,64,0]  𝄀
2020-09-07 08:00:00
delete from t1;
set time_zone = '-05:00';
load data infile '$resources/load_data/timestamp_timezone.csv' into table t1 fields terminated by ',';
select * from t1;
➤ ts[93,64,0]  𝄀
2020-09-07 00:00:00
set time_zone = '+00:00';
select * from t1;
➤ ts[93,64,0]  𝄀
2020-09-07 05:00:00
drop table t1;
set time_zone = 'SYSTEM';
