('00000000-0000-0000-0000-000000000004', '孩子 教育 成长');
create fulltext index ft on t(txt) with parser retrieval;
show create table t;
Table    Create Table
t    CREATE TABLE `t` (\n  `id` uuid NOT NULL,\n  `txt` text DEFAULT NULL,\n  PRIMARY KEY (`id`),\n FULLTEXT `ft`(`txt`) WITH PARSER retrieval\n)
