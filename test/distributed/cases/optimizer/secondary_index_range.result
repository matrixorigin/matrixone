drop database if exists d1;
create database d1;
use d1;
drop table if exists t1;
create table t1(id int primary key, val int, name varchar(50));
create index idx_val on t1(val);
insert into t1 select result, result * 10, concat('row', result) from generate_series(1, 100) g;
select mo_ctl('dn', 'flush', 'd1.t1');
➤ mo_ctl(dn, flush, d1.t1)[12,-1,0]  𝄀
{
  "method": "Flush",
  "result": [
    {
      "returnStr": "OK"
    }
  ]
}

select Sleep(1);
➤ Sleep(1)[-6,8,0]  𝄀
0
explain select * from t1 where val >= 50 and val <= 80;
-- @regex("prefix_between", true)
➤ TP QUERY PLAN[12,0,0]  𝄀
Project  𝄀
  ->  Join  𝄀
        Join Type: INDEX  𝄀
        Join Cond: (t1.id = __mo_index_pri_col)  𝄀
        Runtime Filter Build: #[-1,0]  𝄀
        ->  Table Scan on d1.t1 [ForceOneCN]  𝄀
              Filter Cond: (t1.val <= 80), (t1.val >= 50)  𝄀
              Runtime Filter Probe: t1.id  𝄀
        ->  Index Table Scan on t1.idx_val [ForceOneCN]  𝄀
              Filter Cond: prefix_between(__mo_index_idx_col)
select * from t1 where val >= 50 and val <= 80 order by id;
