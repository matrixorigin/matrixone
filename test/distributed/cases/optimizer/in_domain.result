drop database if exists d_indomain;
create database d_indomain;
use d_indomain;
create table t1(a int primary key, b int);
insert into t1 select result, result from generate_series(20) g;
select a from t1 where a in (1,2,3,4) and a not in (2,3) order by a;
a
1
4
explain select a from t1 where a in (1,2,3,4) and a not in (2,3);
TP QUERY PLAN
Project
  ->  Table Scan on d_indomain.t1
        Filter Cond: t1.a in ([1 4])
select a from t1 where a in (1,2,3,4) and a != 2 and a != 3 order by a;
a
