6
explain select a from t1 where a in (1,2,3,4,5,6,7,8) and a between 3 and 6;
TP QUERY PLAN
Project
  ->  Table Scan on d_indomain.t1
        Filter Cond: t1.a BETWEEN 3 AND 6, t1.a in ([1 2 3 4 5 6 7 8])
insert into t1 values (101, 2);
insert into t1 values (102, 2);
select a,b from t1 where a in (1,101,102) and b != 2 order by a;
a    b
1    1
explain select a,b from t1 where a in (1,101,102) and b != 2;
TP QUERY PLAN
Project
  ->  Table Scan on d_indomain.t1
        Filter Cond: (t1.b <> 2), t1.a in ([1 101 102])
delete from t1 where a in (101, 102);
create table t2(a int, b int);
insert into t2 values (1,1),(2,2),(null,3);
select * from t2 where a in (1,2,3) and a is null;
a    b
explain select * from t2 where a in (1,2,3) and a is null;
