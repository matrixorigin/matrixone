create table twf(ts datetime, p int, v int);
insert into twf values
('2026-01-01 00:00:00', 1, 10), ('2026-01-01 00:00:07', 1, null),
('2026-01-01 00:00:00', 2, null), ('2026-01-01 00:00:07', 2, 40);
select p, _wstart, max(v) from twf group by p interval(ts, 5, second) order by p, _wstart;
➤ p[4,32,0]  ¦  _wstart[93,64,0]  ¦  max(v)[4,32,0]  𝄀
1  ¦  2026-01-01 00:00:00  ¦  10  𝄀
1  ¦  2026-01-01 00:00:05  ¦  null  𝄀
2  ¦  2026-01-01 00:00:00  ¦  null  𝄀
2  ¦  2026-01-01 00:00:05  ¦  40
