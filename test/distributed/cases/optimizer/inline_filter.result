drop database if exists inline_test_db;
create database inline_test_db;
use inline_test_db;
create table t1 (
col_a int,
col_b int,
col_c varchar(20)
);
insert into t1 values
(1,  5,  'row1'),
(2,  10, 'row2'),
(3,  15, 'row3'),
(4,  20, 'row4'),
(5,  25, 'row5'),
(6,  30, 'row6'),
(7,  35, 'row7'),
(8,  40, 'row8'),
(9,  45, 'row9'),
(10, 50, 'row10');
select col_a, col_c from t1 where col_b > 20 order by col_a;
вЮ§ col_a[4,32,0]  ¬¶  col_c[12,-1,0]  рЭДА
5  ¬¶  row5  рЭДА
6  ¬¶  row6  рЭДА
7  ¬¶  row7  рЭДА
8  ¬¶  row8  рЭДА
9  ¬¶  row9  рЭДА
10  ¬¶  row10
explain phyplan select col_a, col_c from t1 where col_b > 20;
