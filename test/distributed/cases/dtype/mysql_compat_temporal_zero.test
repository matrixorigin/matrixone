-- @bvt:issue
-- @bvt:parallel

set time_zone = '+00:00';

select cast('0000-00-00' as date) as zero_date,
       cast('0000-00-00 00:00:00' as datetime) as zero_datetime,
       cast('0000-00-00 00:00:00' as timestamp) as zero_timestamp;
select cast('0000-00-00 00:00:00' as date) as zero_datetime_string_to_date;
select cast(cast('0000-00-00' as date) as signed) as zero_date_signed,
       cast(cast('0000-00-00 00:00:00' as datetime) as decimal(20,6)) as zero_datetime_decimal,
       cast(cast('0000-00-00 00:00:00' as timestamp) as decimal(20,6)) as zero_timestamp_decimal;
select unix_timestamp('0000-00-00 00:00:00') as zero_unix_timestamp;
select unix_timestamp('0000-00-00 00:00:00.000000') as zero_unix_timestamp_fraction;

-- The zero sentinels must not consume the valid minimum calendar value.
select cast('0001-01-01' as date) as minimum_date,
       cast('0001-01-01 00:00:00' as datetime) as minimum_datetime;

drop table if exists mysql_compat_temporal_zero;
drop table if exists mysql_compat_temporal_zero_dml;
create table mysql_compat_temporal_zero(d date, dt datetime, ts timestamp);
create table mysql_compat_temporal_zero_dml(
    id int primary key,
    d date,
    dt datetime,
    ts timestamp
);

set @old_sql_mode = @@sql_mode;

-- NO_ZERO_DATE only rejects zero temporals when a strict mode is also enabled.
set sql_mode = 'STRICT_TRANS_TABLES,NO_ZERO_DATE';
insert into mysql_compat_temporal_zero values
    ('0000-00-00', '0000-00-00 00:00:00', '0000-00-00 00:00:00');
select count(*) as strict_no_zero_date_rows from mysql_compat_temporal_zero;

set sql_mode = 'STRICT_TRANS_TABLES';
insert into mysql_compat_temporal_zero values
    ('0000-00-00', '0000-00-00 00:00:00', '0000-00-00 00:00:00');
select d, dt, ts from mysql_compat_temporal_zero;

truncate table mysql_compat_temporal_zero;
set sql_mode = 'NO_ZERO_DATE';
insert into mysql_compat_temporal_zero values
    ('0000-00-00', '0000-00-00 00:00:00', '0000-00-00 00:00:00');
select d, dt, ts from mysql_compat_temporal_zero;

-- CAST expressions bypass literal conversion and must be rejected by the
-- MultiUpdate write boundary in strict NO_ZERO_DATE mode.
set sql_mode = 'STRICT_TRANS_TABLES,NO_ZERO_DATE';
insert into mysql_compat_temporal_zero_dml values
    (1, cast('0000-00-00' as date), '2024-01-02 03:04:05', '2024-01-02 03:04:05');
insert into mysql_compat_temporal_zero_dml values
    (2, '2024-01-02', cast('0000-00-00 00:00:00' as datetime), '2024-01-02 03:04:05');
insert into mysql_compat_temporal_zero_dml values
    (3, '2024-01-02', '2024-01-02 03:04:05', cast('0000-00-00 00:00:00' as timestamp));
insert into mysql_compat_temporal_zero_dml
    select 4,
           cast('0000-00-00' as date),
           cast('0000-00-00 00:00:00' as datetime),
           cast('0000-00-00 00:00:00' as timestamp);
select count(*) as strict_cast_insert_rows from mysql_compat_temporal_zero_dml;

insert into mysql_compat_temporal_zero_dml values
    (10, '2024-01-02', '2024-01-02 03:04:05', '2024-01-02 03:04:05');
update mysql_compat_temporal_zero_dml
    set d = cast('0000-00-00' as date)
    where id = 10;
update mysql_compat_temporal_zero_dml
    set dt = cast('0000-00-00 00:00:00' as datetime)
    where id = 10;
update mysql_compat_temporal_zero_dml
    set ts = cast('0000-00-00 00:00:00' as timestamp)
    where id = 10;
select id, d, dt, ts from mysql_compat_temporal_zero_dml where id = 10;

-- Either strict mode or NO_ZERO_DATE alone must continue to allow zero values
-- produced by expressions that reach MultiUpdate.
truncate table mysql_compat_temporal_zero_dml;
set sql_mode = 'STRICT_TRANS_TABLES';
insert into mysql_compat_temporal_zero_dml
    select 20,
           cast('0000-00-00' as date),
           cast('0000-00-00 00:00:00' as datetime),
           cast('0000-00-00 00:00:00' as timestamp);
select id, d, dt, ts from mysql_compat_temporal_zero_dml;

truncate table mysql_compat_temporal_zero_dml;
set sql_mode = 'NO_ZERO_DATE';
insert into mysql_compat_temporal_zero_dml
    select 30,
           cast('0000-00-00' as date),
           cast('0000-00-00 00:00:00' as datetime),
           cast('0000-00-00 00:00:00' as timestamp);
select id, d, dt, ts from mysql_compat_temporal_zero_dml;

set sql_mode = @old_sql_mode;
drop table mysql_compat_temporal_zero;
drop table mysql_compat_temporal_zero_dml;
