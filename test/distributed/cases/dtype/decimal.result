DROP TABLE IF EXISTS decimal_neq_test;
CREATE TABLE decimal_neq_test (
id INT PRIMARY KEY,
price DECIMAL(10, 2)
);
INSERT INTO decimal_neq_test VALUES (1, 99.99), (2, 199.99), (3, 299.99);
EXPLAIN SELECT * FROM decimal_neq_test WHERE price <> 99.991234567;
-- @regex("Filter Cond: true", true)
вһӨ TP QUERY PLAN[12,0,0]  рқ„Җ
Project  рқ„Җ
  ->  Table Scan on decimal.decimal_neq_test  рқ„Җ
        Filter Cond: true
SELECT COUNT(*) FROM decimal_neq_test WHERE price <> 99.991234567;
вһӨ COUNT(*)[-5,64,0]  рқ„Җ
3
EXPLAIN SELECT * FROM decimal_neq_test WHERE price <> 99.990000000;
-- @regex("price.*<>.*99.99", true)
вһӨ TP QUERY PLAN[12,0,0]  рқ„Җ
Project  рқ„Җ
  ->  Table Scan on decimal.decimal_neq_test  рқ„Җ
        Filter Cond: (decimal_neq_test.price <> 99.990000000)
SELECT COUNT(*) FROM decimal_neq_test WHERE price <> 99.990000000;
вһӨ COUNT(*)[-5,64,0]  рқ„Җ
2
SELECT COUNT(*) FROM decimal_neq_test WHERE price <> 99.99;
вһӨ COUNT(*)[-5,64,0]  рқ„Җ
2
SELECT * FROM decimal_neq_test WHERE price <> 99.991234567 AND id > 1 ORDER BY id;
вһӨ id[4,32,0]  ВҰ  price[3,10,2]  рқ„Җ
2  ВҰ  199.99  рқ„Җ
3  ВҰ  299.99
DROP TABLE decimal_neq_test;
DROP TABLE IF EXISTS float_precision_test;
CREATE TABLE float_precision_test (
id INT PRIMARY KEY,
f32_col FLOAT,
f64_col DOUBLE
);
INSERT INTO float_precision_test VALUES
(1, 1000000.0, 1000000.0),
(2, 16777216.0, 16777216.0);
SELECT * FROM float_precision_test WHERE f32_col = 1000000;
вһӨ id[4,32,0]  ВҰ  f32_col[7,24,0]  ВҰ  f64_col[8,54,0]  рқ„Җ
1  ВҰ  1000000.0  ВҰ  1000000.0
SELECT * FROM float_precision_test WHERE f32_col = 16777216;
вһӨ id[4,32,0]  ВҰ  f32_col[7,24,0]  ВҰ  f64_col[8,54,0]  рқ„Җ
2  ВҰ  1.6777216E7  ВҰ  1.6777216E7
SELECT COUNT(*) FROM float_precision_test WHERE f32_col = 16777217;
вһӨ COUNT(*)[-5,64,0]  рқ„Җ
0
SELECT * FROM float_precision_test WHERE f64_col = 1000000;
вһӨ id[4,32,0]  ВҰ  f32_col[7,24,0]  ВҰ  f64_col[8,54,0]  рқ„Җ
1  ВҰ  1000000.0  ВҰ  1000000.0
DROP TABLE float_precision_test;
