-- @bvt:issue
-- @bvt:parallel

-- Scalar TIME and a string use string comparison. A TIME column converts a
-- constant string to the column's TIME(scale) before comparison.
select cast('03:04:05.123456' as time(6)) = '030405.123456' as time_eq_compact_string,
       cast('03:04:05.123456' as time(6)) = '03:04:05.123456' as time_eq_formatted_string;
select '030405.123456' = cast('03:04:05.123456' as time(6)) as compact_string_eq_time;
select cast('03:04:05.123456' as time(6)) < '030405.123456' as time_lt_compact_string,
       cast('03:04:05.123456' as time(6)) > '030405.123456' as time_gt_compact_string;
select cast('03:04:05.123456' as time(6)) != '030405.123456' as time_ne_compact_string,
       cast('03:04:05.123456' as time(6)) <=> '030405.123456' as time_null_safe_eq_compact_string,
       cast('03:04:05.123456' as time(6)) <= '030405.123456' as time_le_compact_string,
       cast('03:04:05.123456' as time(6)) >= '030405.123456' as time_ge_compact_string;
select cast('03:04:05.123456' as time(6)) between '030405.123455' and '030405.123457' as time_between_compact_string;

drop table if exists mysql_compat_time_string_compare;
create table mysql_compat_time_string_compare(t time(6));
insert into mysql_compat_time_string_compare values ('03:04:05.123456');
select t = '030405.123456' as time_col_eq_compact_string,
       t between '030405.123455' and '030405.123457' as time_col_between_compact_string
from mysql_compat_time_string_compare;
drop table mysql_compat_time_string_compare;
