id int primary key,
colors set('red', 'green', 'blue')
);
show create table set01;
Table    Create Table
set01    CREATE TABLE `set01` (\n  `id` int NOT NULL,\n  `colors` set('red','green','blue') DEFAULT NULL,\n  PRIMARY KEY (`id`)\n)
