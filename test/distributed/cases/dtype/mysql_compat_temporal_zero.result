drop table if exists mysql_compat_temporal_zero;
create table mysql_compat_temporal_zero(d date, dt datetime, ts timestamp);
set @old_sql_mode = @@sql_mode;
set sql_mode = 'STRICT_TRANS_TABLES,NO_ZERO_DATE';
insert into mysql_compat_temporal_zero values
('0000-00-00', '0000-00-00 00:00:00', '0000-00-00 00:00:00');
truncated type date value 0000-00-00 for column value, 1
