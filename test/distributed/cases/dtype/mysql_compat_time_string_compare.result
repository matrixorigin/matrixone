drop table if exists mysql_compat_time_prepare;
create table mysql_compat_time_prepare(t time(2));
insert into mysql_compat_time_prepare values ('12:00:00.24');
prepare time_col_gt_param from 'select t > ? as time_col_gt_param from mysql_compat_time_prepare';
set @time_param = '2:00:00';
execute time_col_gt_param using @time_param;
➤ time_col_gt_param[-7,1,0]  𝄀
1
deallocate prepare time_col_gt_param;
prepare time_param_lt_col from 'select ? < t as time_param_lt_col from mysql_compat_time_prepare';
execute time_param_lt_col using @time_param;
