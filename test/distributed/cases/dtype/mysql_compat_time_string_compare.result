drop table if exists mysql_compat_time_string_compare;
create table mysql_compat_time_string_compare(t time(6));
insert into mysql_compat_time_string_compare values ('03:04:05.123456');
select t = '030405.123456' as time_col_eq_compact_string,
t between '030405.123455' and '030405.123457' as time_col_between_compact_string
from mysql_compat_time_string_compare;
