set time_zone = '+00:00';
select cast(cast('2024-01-02' as date) as signed) as date_signed;
➤ date_signed[-5,64,0]  𝄀
20240102
select cast(cast('2024-01-02' as date) as decimal(20,0)) as date_decimal;
➤ date_decimal[3,20,0]  𝄀
20240102
select cast('2024-01-02' as date) + 0 as date_plus_zero;
➤ date_plus_zero[-5,64,0]  𝄀
20240102
select cast('2024-01-02' as date) = 20240102 as date_eq_compact_int;
➤ date_eq_compact_int[-7,1,0]  𝄀
1
