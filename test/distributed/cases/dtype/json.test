-- @suite
-- @case
-- @desc:test for json datatype
-- @label:bvt

#Test cases of basic action
DROP TABLE IF EXISTS t1;
create table t1 (a json,b int);
insert into t1 values ('{"t1":"a"}',1),('{"t1":"b"}',2);
select * from t1;
select * from t1 where b=1;
select * from t1 where b=2;
insert into t1 values ('{"t1":"c"',3);
select count(a) from t1;


#Test cases of update and delete
update t1 set a='{"t1":"qaq"}' where b=1;
delete from t1 where b=2;
select * from t1;
delete from t1 where b=1;
select * from t1;

#Test cases of load and export
drop table if exists t2;
create table t2 (a json,b int);
delete from t1;
insert into t1 values ('{"t1":"a"}',1),('{"t1":"b"}',2);
select * from t1 into outfile '$resources/json/export_1.csv' fields enclosed by '"' force_quote(a);
load data infile '$resources/json/export_1.csv' into table t1 fields terminated by ',' ignore 1 lines;
load data infile '$resources/json/export_1.csv' into table t2 fields terminated by ',' ignore 1 lines;
select * from t1;
select * from t2;
select * from t1 into outfile '$resources/json/export_2.csv' fields terminated by '\t';
load data  infile '$resources/json/export_2.csv' into table t1 fields terminated by '\t' ignore 1 lines;
load data  infile '$resources/json/export_2.csv' into table t2 fields terminated by '\t' ignore 1 lines;
select * from t1;
select * from t2;

#Test cases of load
delete from t1;
load data  infile '$resources/json/data_1.csv' into table t1 fields terminated by '\t';
select * from t1;
load data  infile '$resources/json/data_2.csv' into table t1 fields terminated by ',';
select * from t1;
drop table if exists t3;
create table t3 (a json,b json);
load data  infile '$resources/json/data_3.csv' into table t3 fields terminated by ',';
select * from t3;

#Test cases of ddl
drop table if exists t4;
create table t4 (a json null);
drop table if exists t5;
create table t5 (a json not null);
drop table if exists t6;
create table t6 (a json primary key);
drop table if exists t7;
create table t7 (a json default '{"t1":"a"}');
drop table if exists t8;
create table t8 (a json default null);

#Test cases of typed array column
drop table if exists typed_array_json;
create table typed_array_json(id int primary key, tags array(varchar(20)), scores array(int), nested array(array(int)));
desc typed_array_json;
select column_name, data_type, column_type from information_schema.columns where table_schema = database() and table_name = 'typed_array_json' and column_name in ('tags','scores','nested') order by ordinal_position;
insert into typed_array_json values (1, '["red","blue"]', '[1,2,null]', '[[1,2],[3,null]]');
select id, tags, scores, nested from typed_array_json;
insert into typed_array_json(id,tags) values (2, '{"red":true}');
insert into typed_array_json(id,tags) values (3, '[1]');
insert into typed_array_json(id,scores) values (4, '["1"]');
update typed_array_json set tags='{"red":true}' where id=1;
update typed_array_json set scores='[1,"2"]' where id=1;
drop table typed_array_json;
create table typed_array_unsupported(tags array(bit));
drop table if exists typed_array_binary;
create table typed_array_binary(id int primary key, payload array(varbinary(3)));
insert into typed_array_binary values (1, '["abc"]');
insert into typed_array_binary values (2, '["\\u00e9\\u00e9"]');
drop table typed_array_binary;
