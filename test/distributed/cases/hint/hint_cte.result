7  ¦  Product C  ¦  350.00  ¦  2023-04-10  𝄀
8  ¦  Product B  ¦  220.00  ¦  2023-04-25
WITH sales_summary AS (
SELECT
product,
SUM(amount) AS total_amount
FROM test_cte_rewrite.sales
GROUP BY product
)
SELECT * FROM sales_summary
ORDER BY product;
