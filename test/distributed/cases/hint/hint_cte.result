WITH RECURSIVE numbers AS (
SELECT 1 AS n
UNION ALL
SELECT n + 1 FROM numbers WHERE n < 5
),
sales_with_numbers AS (
SELECT
n,
(SELECT COUNT(*) FROM test_cte_rewrite.sales WHERE id <= n) AS cumulative_count
FROM numbers
)
SELECT * FROM sales_with_numbers;
