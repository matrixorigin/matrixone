/*+ {
"rewrites" : {
"test_cte_rewrite.sales" : "SELECT * FROM test_cte_rewrite.sales"
}
} */
WITH north_sales AS (
SELECT
'North' AS region,
SUM(amount) AS total
FROM test_cte_rewrite.sales
WHERE region = 'North'
),
south_sales AS (
SELECT
'South' AS region,
SUM(amount) AS total
FROM test_cte_rewrite.sales
WHERE region = 'South'
)
SELECT * FROM north_sales
UNION ALL
SELECT * FROM south_sales
ORDER BY region;
➤ region[12,-1,0]  ¦  total[3,38,2]  𝄀
North  ¦  470.00  𝄀
South  ¦  450.00
/*+ {
"rewrites" : {
"test_cte_rewrite.sales" : "SELECT * FROM test_cte_rewrite.sales"
}
} */
WITH recent_sales AS (
SELECT
id,
product,
amount,
sale_date
FROM test_cte_rewrite.sales
WHERE sale_date >= '2023-03-01'
)
SELECT * FROM recent_sales
ORDER BY sale_date;
➤ id[4,32,0]  ¦  product[12,-1,0]  ¦  amount[3,10,2]  ¦  sale_date[91,64,0]  𝄀
5  ¦  Product B  ¦  250.00  ¦  2023-03-05  𝄀
