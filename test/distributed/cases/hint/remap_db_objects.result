➤ idx_on[12,-1,0]  𝄀
ddst.qt
set remap_rewrites = '{"remapdb": {"dsrc": "ddst"}}';
drop index qidx on dsrc.qt;
drop view dsrc.qv;
drop table dsrc.qt;
