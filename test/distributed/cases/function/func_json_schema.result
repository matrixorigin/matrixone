select json_schema_validation_report('{"type":"object","required":["name"]}', '{"name":"test"}');
json_schema_validation_report({"type":"object","required":["name"]}, {"name":"test"})
{"valid": true}
select json_schema_validation_report('{"type":"object","required":["name","age"]}', '{"name":"test"}');
json_schema_validation_report({"type":"object","required":["name","age"]}, {"name":"test"})
{"valid": false, "errors": [{"message":"age is required","property":"(root)"}]}
select json_schema_validation_report('{"type":"object","properties":{"x":{"type":"number"}},"required":["x"]}', '{"x":"not_a_number"}');
json_schema_validation_report({"type":"object","properties":{"x":{"type":"number"}},"required":["x"]}, {"x":"not_a_number"})
{"valid": false, "errors": [{"message":"Invalid type. Expected: number, given: string","property":"x"}]}
select json_schema_validation_report('{"type":"number","minimum":0,"maximum":100}', '200');
json_schema_validation_report({"type":"number","minimum":0,"maximum":100}, 200)
{"valid": false, "errors": [{"message":"Must be less than or equal to 100","property":"(root)"}]}
