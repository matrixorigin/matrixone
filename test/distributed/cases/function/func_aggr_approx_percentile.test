select approx_percentile(null, 0.5);

drop table if exists t1;
create table t1 (a int, b int);
insert into t1 values (1, 1), (2, 3), (3, 5), (4, 7), (5, 9);
select approx_percentile(b, 0.5) from t1;
select approx_percentile(b, 0.0) from t1;
select approx_percentile(b, 1.0) from t1;

insert into t1 values (1, 2), (1, 4), (2, 6), (2, 8);
select a, approx_percentile(b, 0.5) from t1 group by a order by a;

drop table if exists t1;
create table t1 (a int, b float);
insert into t1 values (1, 1.1), (2, 2.2), (3, 3.3);
select approx_percentile(b, 0.5) from t1;
select approx_percentile(b, 0.95) from t1;
