drop table if exists t_func_interval;
create table t_func_interval(
id int,
n int,
f double,
d decimal(10,2),
s varchar(20),
t1 int,
t2 int,
t3 int,
st1 varchar(20),
st2 varchar(20)
);
insert into t_func_interval values
(1, 0, 0.5, 0.50, '0', 1, 10, 100, '1', '10'),
