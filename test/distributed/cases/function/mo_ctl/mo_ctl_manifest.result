create table t1(
id int primary key,
name varchar(100),
value float
);
select mo_ctl('dn', 'inspect', 'manifest -t mo_ctl_manifest.t1');
mo_ctl(dn, inspect, manifest -t mo_ctl_manifest.t1)
ignored
insert into t1 values (1, 'alice', 10.5), (2, 'bob', 20.5), (3, 'carol', 30.5);
select mo_ctl('dn', 'flush', 'mo_ctl_manifest.t1');
mo_ctl(dn, flush, mo_ctl_manifest.t1)
ignored
select sleep(1);
sleep(1)
0
