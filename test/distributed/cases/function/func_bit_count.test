-- @suit
-- @case
-- @desc:test for function bit_count()
-- @label:bvt

# Basic examples
SELECT BIT_COUNT(64), BIT_COUNT(BINARY 64);
SELECT BIT_COUNT('64'), BIT_COUNT(_binary '64');
SELECT BIT_COUNT(X'40'), BIT_COUNT(_binary X'40');
SELECT BIT_COUNT(NULL);

# Numeric values
SELECT BIT_COUNT(0), BIT_COUNT(1), BIT_COUNT(2), BIT_COUNT(3), BIT_COUNT(255), BIT_COUNT(256);
SELECT BIT_COUNT(-1), BIT_COUNT(-2), BIT_COUNT(-9223372036854775808);
SELECT BIT_COUNT(CAST('9223372036854775806' AS BIGINT)), BIT_COUNT(CAST('9223372036854775807' AS BIGINT));
SELECT BIT_COUNT(CAST('-9223372036854775807' AS BIGINT)), BIT_COUNT(CAST('-9223372036854775808' AS BIGINT));
SELECT BIT_COUNT(CAST(64 AS TINYINT)), BIT_COUNT(CAST(64 AS SMALLINT)), BIT_COUNT(CAST(64 AS INT)), BIT_COUNT(CAST(64 AS BIGINT));
SELECT BIT_COUNT(CAST(-1 AS TINYINT)), BIT_COUNT(CAST(-1 AS SMALLINT)), BIT_COUNT(CAST(-1 AS INT)), BIT_COUNT(CAST(-1 AS BIGINT));
SELECT BIT_COUNT(CAST(255 AS TINYINT UNSIGNED)), BIT_COUNT(CAST(65535 AS SMALLINT UNSIGNED)), BIT_COUNT(CAST(4294967295 AS INT UNSIGNED));
SELECT BIT_COUNT(CAST('4294967296' AS BIGINT UNSIGNED)), BIT_COUNT(CAST('9223372036854775808' AS BIGINT UNSIGNED));
SELECT BIT_COUNT(CAST('18446744073709551614' AS BIGINT UNSIGNED)), BIT_COUNT(CAST('18446744073709551615' AS BIGINT UNSIGNED));
SELECT BIT_COUNT(CAST(64.9 AS FLOAT)), BIT_COUNT(CAST(64.9 AS DOUBLE));
SELECT BIT_COUNT(CAST(64.9 AS DECIMAL(10, 1))), BIT_COUNT(CAST(255.9 AS DECIMAL(10, 1)));
SELECT BIT_COUNT(CAST(1.4 AS FLOAT)), BIT_COUNT(CAST(1.5 AS FLOAT)), BIT_COUNT(CAST(2.5 AS FLOAT)), BIT_COUNT(CAST(3.5 AS FLOAT));
SELECT BIT_COUNT(CAST(4.5 AS FLOAT)), BIT_COUNT(CAST(5.5 AS FLOAT)), BIT_COUNT(CAST(6.5 AS FLOAT)), BIT_COUNT(CAST(7.5 AS FLOAT));
SELECT BIT_COUNT(CAST(-1.4 AS DOUBLE)), BIT_COUNT(CAST(-1.5 AS DOUBLE)), BIT_COUNT(CAST(-2.5 AS DOUBLE)), BIT_COUNT(CAST(-3.5 AS DOUBLE));
SELECT BIT_COUNT(CAST(-4.5 AS DOUBLE)), BIT_COUNT(CAST(-5.5 AS DOUBLE)), BIT_COUNT(CAST(-6.5 AS DOUBLE)), BIT_COUNT(CAST(-7.5 AS DOUBLE));
SELECT BIT_COUNT(CAST('9223372036854774784' AS DOUBLE)), BIT_COUNT(CAST('9223372036854775807' AS DOUBLE));
SELECT BIT_COUNT(CAST('9223372036854775808' AS DOUBLE)), BIT_COUNT(CAST('-9223372036854775809' AS DOUBLE));
SELECT BIT_COUNT(CAST('-9223372036854774784' AS DOUBLE)), BIT_COUNT(CAST('-9223372036854775808' AS DOUBLE));
SELECT BIT_COUNT(CAST(1.4 AS DECIMAL(10, 1))), BIT_COUNT(CAST(1.5 AS DECIMAL(10, 1))), BIT_COUNT(CAST(2.5 AS DECIMAL(10, 1))), BIT_COUNT(CAST(-1.4 AS DECIMAL(10, 1))), BIT_COUNT(CAST(-1.5 AS DECIMAL(10, 1))), BIT_COUNT(CAST(-2.5 AS DECIMAL(10, 1)));
SELECT BIT_COUNT(CAST(2.4 AS DECIMAL(10, 1))), BIT_COUNT(CAST(2.5 AS DECIMAL(10, 1))), BIT_COUNT(CAST(2.6 AS DECIMAL(10, 1))), BIT_COUNT(CAST(-2.4 AS DECIMAL(10, 1))), BIT_COUNT(CAST(-2.5 AS DECIMAL(10, 1))), BIT_COUNT(CAST(-2.6 AS DECIMAL(10, 1)));
SELECT BIT_COUNT(CAST('9223372036854775807' AS DECIMAL(38, 0))), BIT_COUNT(CAST('9223372036854775808' AS DECIMAL(38, 0)));
SELECT BIT_COUNT(CAST('9223372036854775807.4' AS DECIMAL(38, 1))), BIT_COUNT(CAST('9223372036854775807.5' AS DECIMAL(38, 1)));
SELECT BIT_COUNT(CAST('-9223372036854775807.4' AS DECIMAL(38, 1))), BIT_COUNT(CAST('-9223372036854775807.5' AS DECIMAL(38, 1)));
SELECT BIT_COUNT(CAST('18446744073709551615' AS DECIMAL(38, 0))), BIT_COUNT(CAST('18446744073709551616' AS DECIMAL(38, 0))), BIT_COUNT(CAST('-9223372036854775808' AS DECIMAL(38, 0))), BIT_COUNT(CAST('-18446744073709551616' AS DECIMAL(38, 0)));
SELECT BIT_COUNT(CAST('99999999999999999999999999999999999999' AS DECIMAL(38, 0))), BIT_COUNT(CAST('-99999999999999999999999999999999999999' AS DECIMAL(38, 0)));
SELECT BIT_COUNT(CAST('9999999999999999999999999999999999999.5' AS DECIMAL(38, 1))), BIT_COUNT(CAST('-9999999999999999999999999999999999999.5' AS DECIMAL(38, 1)));
SELECT BIT_COUNT(CAST('99999999999999999999999999999999999999999999999999999999999999999' AS DECIMAL(65, 0))), BIT_COUNT(CAST('-99999999999999999999999999999999999999999999999999999999999999999' AS DECIMAL(65, 0)));
SELECT BIT_COUNT(CAST('9999999999999999999999999999999999999999999999999999999999999999.5' AS DECIMAL(65, 1))), BIT_COUNT(CAST('-9999999999999999999999999999999999999999999999999999999999999999.5' AS DECIMAL(65, 1)));

# Nonbinary string values are converted to BIGINT
SELECT BIT_COUNT('0'), BIT_COUNT('1'), BIT_COUNT('64'), BIT_COUNT('255'), BIT_COUNT('-1');
SELECT BIT_COUNT(CAST('64' AS CHAR)), BIT_COUNT(CAST('64' AS VARCHAR(10))), BIT_COUNT(CAST('64' AS TEXT));
SELECT BIT_COUNT(''), BIT_COUNT('   '), BIT_COUNT(CAST('' AS CHAR)), BIT_COUNT(CAST('' AS VARCHAR(10))), BIT_COUNT(CAST('' AS TEXT));
SELECT BIT_COUNT('+1'), BIT_COUNT('9223372036854775808'), BIT_COUNT('18446744073709551615'), BIT_COUNT('18446744073709551616');
SELECT BIT_COUNT('-9223372036854775808'), BIT_COUNT('-18446744073709551616');
SELECT BIT_COUNT(CAST('18446744073709551615' AS CHAR)), BIT_COUNT(CAST('-18446744073709551616' AS VARCHAR(32)));

# Binary string values count set bits in bytes
SELECT BIT_COUNT(BINARY '64'), BIT_COUNT(_binary '64'), BIT_COUNT(CAST('64' AS BINARY)), BIT_COUNT(CAST('64' AS VARBINARY(2)));
SELECT BIT_COUNT(BINARY ''), BIT_COUNT(_binary ''), BIT_COUNT(CAST('' AS BINARY)), BIT_COUNT(CAST('' AS VARBINARY(2)));
SELECT BIT_COUNT(X'00'), BIT_COUNT(X'01'), BIT_COUNT(X'40'), BIT_COUNT(X'FF'), BIT_COUNT(X'FFFF');
SELECT BIT_COUNT(_binary X'00'), BIT_COUNT(_binary X'01'), BIT_COUNT(_binary X'40'), BIT_COUNT(_binary X'FF'), BIT_COUNT(_binary X'FFFF');
SELECT BIT_COUNT(X'0102030405060708'), BIT_COUNT(X'FFFFFFFFFFFFFFFF'), BIT_COUNT(X'FFFFFFFFFFFFFFFFFF');
SELECT BIT_COUNT(UNHEX('40')), BIT_COUNT(UNHEX('FF')), BIT_COUNT(UNHEX('FFFF'));

# Table usage
DROP TABLE IF EXISTS t_bit_count;
CREATE TABLE t_bit_count(
    id INT,
    i BIGINT,
    u BIGINT UNSIGNED,
    s VARCHAR(10),
    b VARBINARY(4)
);
INSERT INTO t_bit_count VALUES
    (1, 64, 64, '64', X'40'),
    (2, -1, 255, '-1', X'FF'),
    (3, NULL, NULL, NULL, NULL);
SELECT id, BIT_COUNT(i), BIT_COUNT(u), BIT_COUNT(s), BIT_COUNT(b) FROM t_bit_count ORDER BY id;
SELECT id FROM t_bit_count WHERE BIT_COUNT(b) = 1 ORDER BY id;
DROP TABLE t_bit_count;
