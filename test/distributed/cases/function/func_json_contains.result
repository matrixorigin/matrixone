➤ id[4,32,0]  𝄀
1  𝄀
3
drop table if exists t_json_contains_json;
create table t_json_contains_json (id int, doc json);
insert into t_json_contains_json values
(1, '{"items":[{"sku":"a","qty":2},{"sku":"b","qty":1}]}'),
(2, '{"items":[{"sku":"c","qty":5}]}'),
(3, '{"items":[]}'),
(4, 'null');
select id, json_contains(doc, '{"sku":"a"}', '$.items') as has_sku_a from t_json_contains_json order by id;
➤ id[4,32,0]  ¦  has_sku_a[-5,64,0]  𝄀
1  ¦  1  𝄀
2  ¦  0  𝄀
3  ¦  0  𝄀
4  ¦  null
