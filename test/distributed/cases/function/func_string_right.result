drop table if exists t_right;
create table t_right(str varchar(100), ch char(20), len int);
insert into t_right values('abcdefghijklmn', 'HELLOWORLD', 3);
insert into t_right values('  ABCDEFGH123456', 'ABCDE     ', 5);
insert into t_right values('ABCDEF  GHIJKLMN', 'XYZ', 20);
insert into t_right values('ABCDEFGHijklmn   ', 'short', -1);
insert into t_right values('', '', 3);
insert into t_right values(null, null, 2);
insert into t_right values('nullable length', 'nullable', null);
select right(str, len), right(ch, len) from t_right;
