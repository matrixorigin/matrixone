SELECT POSITION('World' IN 'Hello World') AS result1;
result1
7
SELECT POSITION('Hello' IN 'Hello World') AS at_beginning;
at_beginning
1
SELECT POSITION('World' IN 'Hello World') AS in_middle;
in_middle
7
SELECT POSITION('test' IN 'Hello World') AS not_found;
not_found
0
SELECT POSITION('' IN 'Hello World') AS empty_substr;
empty_substr
1
SELECT POSITION('o' IN 'Hello World') AS single_char;
single_char
5
SELECT POSITION(NULL IN 'Hello World') AS null_substr;
null_substr
null
SELECT POSITION('World' IN NULL) AS null_str;
null_str
null
SELECT POSITION(NULL IN NULL) AS both_null;
both_null
null
CREATE TABLE t1(substr VARCHAR(50), str VARCHAR(50));
INSERT INTO t1 VALUES ('World', 'Hello World'), ('Hello', 'Hello World'), ('test', 'Hello World');
SELECT substr, str, POSITION(substr IN str) AS position FROM t1;
substr    str    position
World    Hello World    7
Hello    Hello World    1
test    Hello World    0
DROP TABLE t1;
CREATE TABLE t1(substr VARCHAR(50), str VARCHAR(50));
INSERT INTO t1 VALUES ('World', 'Hello World'), ('Hello', 'Hello World'), ('test', 'Hello World');
SELECT * FROM t1 WHERE POSITION(substr IN str) > 0;
substr    str
World    Hello World
Hello    Hello World
DROP TABLE t1;
SELECT POSITION('World' IN 'Hello World') AS position_result, LOCATE('World', 'Hello World') AS locate_result;
position_result    locate_result
7    7
