grace  ¦  60000.00  ¦  0.9  𝄀
frank  ¦  50000.00  ¦  1.0
select
employee,
salary,
cume_dist() over (order by salary) as cd,
percent_rank() over (order by salary) as pr
from test_cd_basic
order by salary;
