select st_astext(st_interiorringn(st_geomfromtext('POLYGON((0 0,20 0,20 20,0 20,0 0),(5 5,15 5,15 15,5 15,5 5))'), 1)) as first_hole;
➤ first_hole[12,-1,0]  𝄀
LINESTRING(5 5,15 5,15 15,5 15,5 5)
select st_astext(st_interiorringn(st_geomfromtext('POLYGON((0 0,30 0,30 30,0 30,0 0),(5 5,10 5,10 10,5 10,5 5),(15 15,20 15,20 20,15 20,15 15))'), 2)) as second_hole;
➤ second_hole[12,-1,0]  𝄀
LINESTRING(15 15,20 15,20 20,15 20,15 15)
select st_srid(st_interiorringn(st_geomfromtext('POLYGON((0 0,2 0,2 2,0 2,0 0),(0.5 0.5,1 0.5,1 1,0.5 1,0.5 0.5))', 4326), 1)) as srid_interior_ring;
➤ srid_interior_ring[4,32,0]  𝄀
4326
select st_astext(st_interiorringn(st_geomfromtext(null), 1)) as null_geometry;
➤ null_geometry[12,-1,0]  𝄀
null
select st_astext(st_interiorringn(st_geomfromtext('POLYGON((0 0,20 0,20 20,0 20,0 0),(5 5,15 5,15 15,5 15,5 5))'), null)) as null_index;
➤ null_index[12,-1,0]  𝄀
null
select st_interiorringn(st_geomfromtext('POINT(1 1)'), 1);
-- @regex("geometry is not a POLYGON", true)
invalid input: geometry is not a POLYGON
select st_interiorringn(st_geomfromtext('POLYGON((0 0,20 0,20 20,0 20,0 0),(5 5,15 5,15 15,5 15,5 5))'), 2);
