select st_astext(st_pointonsurface(st_geomfromtext('POINT(1 2)'))) as point_surface;
select st_astext(st_pointonsurface(st_geomfromtext('LINESTRING(0 0,4 0,4 2)'))) as line_surface;
select st_astext(st_pointonsurface(st_geomfromtext('POLYGON((0 0,4 0,4 4,0 4,0 0))'))) as polygon_surface;
select st_astext(st_pointonsurface(st_geomfromtext('POLYGON((0 0,6 0,6 6,0 6,0 0),(2 2,4 2,4 4,2 4,2 2))'))) as polygon_hole_surface;
select st_srid(st_pointonsurface(st_geomfromtext('POLYGON((0 0,2 0,2 2,0 2,0 0))', 4326))) as srid_surface;
select st_astext(st_pointonsurface(st_geomfromtext(null))) as null_surface;
-- @regex("geometry type is not supported by ST_PointOnSurface",true)
select st_pointonsurface(st_geomfromtext('MULTIPOINT((0 0),(1 1))'));
