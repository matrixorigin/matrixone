-- @suit
-- @case
-- @desc:test for SUBTIME
-- @label:bvt

select cast(subtime('2008-01-02 01:01:01.000001', '1 1:1:1.000002') as char) q1;
select time(subtime('12:30:45', '01:15:30')) q2;
select cast(subtime(cast('2024-01-02 00:00:00' as datetime), '24:00:00') as char) q3;
select subtime(null, '01:00:00') is null q4;
