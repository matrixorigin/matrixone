select st_astext(st_boundary(st_geomfromtext('LINESTRING(0 0,2 2,4 2)'))) as open_line_boundary;
select st_astext(st_boundary(st_geomfromtext('LINESTRING(0 0,2 0,1 1,0 0)'))) as closed_line_boundary;
select st_astext(st_boundary(st_geomfromtext('POLYGON((0 0,4 0,4 4,0 4,0 0),(1 1,3 1,3 3,1 3,1 1))'))) as polygon_boundary;
select st_srid(st_boundary(st_geomfromtext('POLYGON((0 0,2 0,2 2,0 2,0 0))', 4326))) as srid_boundary;
select st_astext(st_boundary(st_geomfromtext(null))) as null_boundary;
-- @regex("geometry type is not supported by ST_Boundary",true)
select st_boundary(st_geomfromtext('POINT(1 2)'));
