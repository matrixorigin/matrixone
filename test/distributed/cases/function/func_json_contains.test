-- json_contains basic scalar/object/array containment
select json_contains('1', '1');
select json_contains('1', '2');
select json_contains('"x"', '"x"');
select json_contains('"x"', '"y"');
select json_contains('true', 'true');
select json_contains('true', 'false');
select json_contains('null', 'null');

-- MySQL documented examples
select json_contains('{"a": 1, "b": 2, "c": {"d": 4}}', '1', '$.a');
select json_contains('{"a": 1, "b": 2, "c": {"d": 4}}', '1', '$.b');
select json_contains('{"a": 1, "b": 2, "c": {"d": 4}}', '{"d": 4}', '$.a');
select json_contains('{"a": 1, "b": 2, "c": {"d": 4}}', '{"d": 4}', '$.c');

-- Prisma-style path filters
select json_contains('{"tags":["x","y"]}', '"x"', '$.tags');
select json_contains('{"tags":["x","y"]}', '"z"', '$.tags');
select json_contains('{"type":"doc","tags":["x","y"]}', '"doc"', '$.type');
select json_contains('{"type":"doc","tags":["x","y"]}', '"page"', '$.type');

-- array containment
select json_contains('[1,2,3]', '1');
select json_contains('[1,2,3]', '[1,3]');
select json_contains('[1,2,3]', '[1,4]');
select json_contains('["a","b","c"]', '["b","a"]');
select json_contains('[{"a":1},{"b":2}]', '{"b":2}');
select json_contains('[{"a":1},{"b":2}]', '{"b":3}');
select json_contains('[{"a":1,"b":2},{"a":3}]', '[{"a":1},{"a":3}]');

-- object containment
select json_contains('{"a":1,"b":{"c":2,"d":3}}', '{"b":{"c":2}}');
select json_contains('{"a":1,"b":{"c":2,"d":3}}', '{"b":{"c":4}}');
select json_contains('{"a":1,"b":2}', '{"a":1,"c":3}');
select json_contains('{"a":[1,2,{"b":3}]}', '{"a":[{"b":3}]}');
select json_contains('{"a":[1,2,{"b":3}]}', '{"a":[{"b":4}]}');

-- path existence and json null
select json_contains('{"a": null}', 'null', '$.a');
select json_contains('{"a": null}', '1', '$.a');
select json_contains('{"a": 1}', '1', '$.missing');
select json_contains('[1,2,3]', '2', '$[1]');
select json_contains('[1,2,3]', '4', '$[1]');
select json_contains('[1,{"a":["x","y"]}]', '"y"', '$[1].a');

-- null arguments
select json_contains(null, '1');
select json_contains('{"a":1}', null);
select json_contains('{"a":1}', '1', null);

-- T_json inputs via cast/json_object/json_array
select json_contains(cast('{"a":1,"b":[1,2,3]}' as json), '1', '$.a');
select json_contains(cast('{"a":1,"b":[1,2,3]}' as json), '[1,2]', '$.b');
select json_contains(json_object('k1', 1, 'k2', json_array(1, 2, 3)), '1', '$.k1');
select json_contains(json_object('k1', 1, 'k2', json_array(1, 2, 3)), '[2,3]', '$.k2');
select json_contains(json_array(1, 2, 3), '[1,2]');
select json_contains(json_array(1, 2, 3), '2', '$[1]');
select json_contains('{"a":{"b":1,"c":2}}', json_object('b', 1), '$.a');

-- INTEGER/DECIMAL comparable
select json_contains('1', '1.0');
select json_contains('{"a":1}', '{"a":1.0}');
select json_contains('[1,2,3]', '[1.0,3.0]');

-- candidate string must be a valid JSON string literal
select json_contains('{"a":"x"}', '"x"', '$.a');
select json_contains('{"a":"x"}', 'x', '$.a');

-- invalid JSON/path inputs
select json_contains('invalid', '1');
select json_contains('{"a":1}', 'invalid');
select json_contains('{"a":1}', '1', '');
select json_contains('{"a":[1,2]}', '1', '$.a[*]');
select json_contains('{"a":{"b":1}}', '1', '$**.b');
select json_contains(cast('{"a":1}' as json), '1', '$.*');

-- json and varchar columns
drop table if exists t_json_contains_varchar;
create table t_json_contains_varchar (id int, doc varchar(200));
insert into t_json_contains_varchar values
(1, '{"type":"doc","tags":["x","y"],"meta":{"published":true}}'),
(2, '{"type":"page","tags":["z"],"meta":{"published":false}}'),
(3, '{"type":"doc","tags":[],"meta":{"published":null}}'),
(4, null);
select id, json_contains(doc, '"doc"', '$.type') as is_doc from t_json_contains_varchar order by id;
select id from t_json_contains_varchar where json_contains(doc, '"x"', '$.tags') order by id;
select id, json_contains(doc, 'true', '$.meta.published') as is_published from t_json_contains_varchar order by id;

drop table if exists t_json_contains_json;
create table t_json_contains_json (id int, doc json);
insert into t_json_contains_json values
(1, '{"items":[{"sku":"a","qty":2},{"sku":"b","qty":1}]}'),
(2, '{"items":[{"sku":"c","qty":5}]}'),
(3, '{"items":[]}'),
(4, 'null');
select id, json_contains(doc, '{"sku":"a"}', '$.items') as has_sku_a from t_json_contains_json order by id;
select id from t_json_contains_json where json_contains(doc, '{"sku":"c"}', '$.items') order by id;
select id from t_json_contains_json where json_contains(doc, '{"items":[{"qty":5}]}') order by id;

drop table t_json_contains_varchar;
drop table t_json_contains_json;
