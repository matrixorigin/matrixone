CREATE TABLE t1(str VARCHAR(50), pos INT, len INT, newstr VARCHAR(50));
INSERT INTO t1 VALUES ('Hello World', 7, 5, 'MySQL'), ('MatrixOne', 1, 6, 'MySQL'), ('Test', 5, 0, ' Result');
SELECT str, pos, len, newstr, INSERT(str, pos, len, newstr) AS result FROM t1;
