select name_const('myname', 14);
➤ myname[-5,64,0]  𝄀
14
select name_const('neg_int_name', -1);
➤ neg_int_name[-5,64,0]  𝄀
-1
select name_const('uint64_name', 18446744073709551615);
➤ uint64_name[-5,64,0]  𝄀
18446744073709551615
select name_const('str_name', 'abc');
➤ str_name[12,-1,0]  𝄀
abc
select name_const('null_name', null);
➤ null_name[12,-1,0]  𝄀
null
select name_const('decimal_name', 12.34);
➤ decimal_name[3,18,2]  𝄀
12.34
select name_const('neg_decimal_name', -12.34);
➤ neg_decimal_name[3,18,2]  𝄀
-12.34
select name_const(123, -456);
➤ 123[-5,64,0]  𝄀
-456
select name_const('myname', 14) as alias_name;
➤ alias_name[-5,64,0]  𝄀
14
select name_const('expr_name', 14) + 1;
➤ name_const(expr_name, 14) + 1[-5,64,0]  𝄀
15
