select name, type, algo, column_name
from mo_catalog.mo_indexes
where name = 'idx_g'
and table_id = (
select rel_id
from mo_catalog.mo_tables
where reldatabase = database()
and relname = 'spatial_idx_t1'
)
order by column_name;
