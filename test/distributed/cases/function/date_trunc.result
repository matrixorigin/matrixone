drop database if exists date_trunc_db;
create database date_trunc_db;
use date_trunc_db;
set time_zone = '+00:00';
select date_trunc('year', cast('2024-05-16 12:34:56.123456' as datetime));
date_trunc(year, cast(2024-05-16 12:34:56.123456 as datetime))
