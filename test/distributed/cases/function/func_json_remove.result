➤ id[4,32,0]  ¦  info[-1,2147483647,0]  𝄀
1  ¦  {"age": 30, "name": "Alice", "skills": ["Go", "Python"]}  𝄀
2  ¦  {"address": {"city": "Beijing", "zip": "100000"}, "age": 25, "name": "Bob"}
UPDATE json_remove_users
SET info = JSON_REMOVE(info, '$.address.zip', '$.missing')
WHERE id = 2;
