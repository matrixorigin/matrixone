SELECT JSON_REMOVE('{"a":1,"b":2}', '$.a') AS result;
➤ result[-1,2147483647,0]  𝄀
{"b": 2}
SELECT JSON_REMOVE('["a", ["b", "c"], "d"]', '$[1]') AS result;
➤ result[-1,2147483647,0]  𝄀
["a", "d"]
SELECT JSON_REMOVE('{"a":{"b":1,"c":2},"d":3}', '$.a.b') AS result;
➤ result[-1,2147483647,0]  𝄀
{"a": {"c": 2}, "d": 3}
SELECT JSON_REMOVE('{"a":1}', '$.missing') AS result;
➤ result[-1,2147483647,0]  𝄀
