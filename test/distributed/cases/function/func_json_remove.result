SELECT JSON_REMOVE('["a","b","c","d"]', '$[1]', '$[1]') AS result;
➤ result[-1,2147483647,0]  𝄀
["a", "d"]
SELECT JSON_REMOVE('{"a":1,"b":2,"c":3}', '$.a', '$.c') AS result;
➤ result[-1,2147483647,0]  𝄀
{"b": 2}
