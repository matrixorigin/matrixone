SELECT JSON_REMOVE('{"a":1}', '$.a.b') AS result;
➤ result[-1,2147483647,0]  𝄀
{"a": 1}
SELECT JSON_REMOVE('{"a":1,"b":2}', '$.a[0]') AS result;
➤ result[-1,2147483647,0]  𝄀
{"b": 2}
SELECT JSON_REMOVE('{"a":1,"b":2}', '$[0].a') AS result;
➤ result[-1,2147483647,0]  𝄀
