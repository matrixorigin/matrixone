Table    Create Table
spatial_idx_nullable    CREATE TABLE `spatial_idx_nullable` (\n  `id` int NOT NULL,\n  `g` geometry DEFAULT NULL,\n  `payload` int DEFAULT NULL,\n  PRIMARY KEY (`id`),\n  SPATIAL KEY `idx_g` (`g`)\n)
