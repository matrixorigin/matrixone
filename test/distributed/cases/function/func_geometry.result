id
1
select id from spatial_idx_nonpoint where st_contains(g, st_geomfromtext('POINT(1 1)')) order by id;
id
2
select id from spatial_idx_nonpoint where st_distance(g, st_geomfromtext('POINT(5 5)')) <= 0 order by id;
id
3
update spatial_idx_nonpoint
set g = st_geomfromtext('GEOMETRYCOLLECTION(POINT(7 7),LINESTRING(7 7,8 8))')
where id = 3;
select id from spatial_idx_nonpoint where st_intersects(g, st_geomfromtext('POINT(7 7)')) order by id;
id
3
delete from spatial_idx_nonpoint where id = 2;
select id from spatial_idx_nonpoint where st_contains(g, st_geomfromtext('POINT(1 1)')) order by id;
id
drop table spatial_idx_nonpoint;
drop table if exists spatial_idx_t2;
create table spatial_idx_t2(
id int primary key,
a int
);
create spatial index idx_a on spatial_idx_t2(a);
not supported: SPATIAL INDEX can only be created on GEOMETRY column 'a'
drop table spatial_idx_t2;
drop table if exists spatial_idx_multi;
create table spatial_idx_multi(
id int primary key,
g1 point,
g2 point
);
create spatial index idx_g on spatial_idx_multi(g1, g2);
not supported: SPATIAL INDEX only supports a single GEOMETRY column
drop table spatial_idx_multi;
drop table if exists spatial_idx_nullable;
create table spatial_idx_nullable(
id int primary key,
g geometry,
payload int
);
create spatial index idx_g on spatial_idx_nullable(g);
