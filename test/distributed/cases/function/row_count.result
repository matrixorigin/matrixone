drop database if exists row_count_db;
create database row_count_db;
use row_count_db;
create table t(id int primary key, v int);
insert into t values (1,10),(2,20);
select row_count();
➤ row_count()[-5,64,0]  𝄀
2
insert into t values (3,30);
select row_count();
➤ row_count()[-5,64,0]  𝄀
1
insert ignore into t values (4,40);
select row_count();
➤ row_count()[-5,64,0]  𝄀
1
insert ignore into t values (1,99);
select row_count();
➤ row_count()[-5,64,0]  𝄀
0
update t set v=v+1 where id in (1,2,3);
select row_count();
➤ row_count()[-5,64,0]  𝄀
3
update t set v=0 where id=999;
select row_count();
➤ row_count()[-5,64,0]  𝄀
0
delete from t where id=4;
select row_count();
➤ row_count()[-5,64,0]  𝄀
1
replace into t values (50,500);
select row_count();
➤ row_count()[-5,64,0]  𝄀
1
select v from t where id=1;
➤ v[4,32,0]  𝄀
11
select row_count();
➤ row_count()[-5,64,0]  𝄀
-1
select row_count();
➤ row_count()[-5,64,0]  𝄀
-1
create table t2(a int);
select row_count();
➤ row_count()[-5,64,0]  𝄀
0
create table src(a int);
insert into src values (1),(2),(3),(4),(5),(6);
select row_count();
➤ row_count()[-5,64,0]  𝄀
6
create table ctas as select * from src;
select row_count();
➤ row_count()[-5,64,0]  𝄀
6
insert into t values (1,12345);
Duplicate entry '1' for key 'id'
select row_count();
➤ row_count()[-5,64,0]  𝄀
-1
insert into t values (6,60),(7,70);
prepare stmt1 from 'select row_count()';
delete from t where id in (1,2,3);
execute stmt1;
➤ row_count()[-5,64,0]  𝄀
3
deallocate prepare stmt1;
drop database if exists row_count_db;
