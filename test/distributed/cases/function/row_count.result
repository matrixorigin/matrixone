drop database if exists row_count_db;
create database row_count_db;
use row_count_db;
create table t(id int primary key, v int);
insert into t values (1,10),(2,20);
select row_count();
➤ row_count()[-5,64,0]  𝄀
2
insert into t values (3,30);
select row_count();
➤ row_count()[-5,64,0]  𝄀
1
insert ignore into t values (4,40);
select row_count();
➤ row_count()[-5,64,0]  𝄀
1
insert ignore into t values (1,99);
select row_count();
➤ row_count()[-5,64,0]  𝄀
0
update t set v=v+1 where id in (1,2,3);
select row_count();
➤ row_count()[-5,64,0]  𝄀
3
update t set v=0 where id=999;
select row_count();
➤ row_count()[-5,64,0]  𝄀
0
delete from t where id=4;
select row_count();
➤ row_count()[-5,64,0]  𝄀
1
replace into t values (1,1000);
select row_count();
➤ row_count()[-5,64,0]  𝄀
1
select v from t where id=1;
➤ v[4,32,0]  𝄀
1000
select row_count();
➤ row_count()[-5,64,0]  𝄀
-1
select row_count();
➤ row_count()[-5,64,0]  𝄀
-1
create table t2(a int);
select row_count();
➤ row_count()[-5,64,0]  𝄀
0
drop database if exists row_count_db;
