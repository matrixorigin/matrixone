select st_astext(cast('POINT(1 2)' as geometry)) as point_text;
select st_astext(cast('POLYGON((0 0,1 0,1 1,0 0))' as geometry)) as polygon_text;
select st_astext(cast(null as geometry)) as null_text;
-- @regex("invalid geometry payload",true)
select st_astext(cast('INVALID' as geometry)) as invalid_geom;
-- @regex("invalid geometry payload",true)
select st_astext(cast('POINT(NaN 1)' as geometry)) as invalid_nan_geom;
select st_geomfromtext('POINT(7 8)', 4326) as direct_geom;
-- @regex("invalid geometry type",true)
select cast('SRID=4326;POINT(9 9)' as geometry) as raw_payload_geom;

drop table if exists t1;
create table t1(g geometry);
insert into t1 values ('LINESTRING(0 0,1 1)'), ('POINT(3 4)');
select st_astext(g) as geom_text from t1 order by 1;
drop table t1;

drop table if exists t_invalid_geom;
create table t_invalid_geom(g geometry);
-- @regex("invalid geometry payload",true)
insert into t_invalid_geom values ('INVALID');
-- @regex("invalid geometry payload",true)
insert into t_invalid_geom values ('POINT(NaN 1)');
drop table t_invalid_geom;
