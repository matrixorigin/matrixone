create database if not exists geo_srid_db;
use geo_srid_db;

drop table if exists geo_srid_show;
create table geo_srid_show (
    id int primary key,
    location point not null srid 4326
);
show create table geo_srid_show;
desc geo_srid_show;
show columns from geo_srid_show;
drop table geo_srid_show;

drop table if exists geo_srid_value_ok;
create table geo_srid_value_ok(g point not null srid 4326);
insert into geo_srid_value_ok values (st_geomfromtext('POINT(1 1)', 4326));
select st_astext(g) as point_text, st_srid(g) as point_srid from geo_srid_value_ok;
select st_astext(st_geomfromtext('POINT EMPTY', 4326)) as empty_point_text, st_srid(st_geomfromtext('POINT EMPTY', 4326)) as empty_point_srid;
-- @regex("SRID should be between 0 and 4294967295",true)
select st_geomfromtext('POINT(1 1)', 5000000000);
-- @regex("invalid geometry payload",true)
select st_geomfromtext('POINT(Inf 1)', 4326);
drop table geo_srid_value_ok;

drop table if exists geo_srid_value_bad;
create table geo_srid_value_bad(g point not null srid 4326);
-- @regex("The SRID of the geometry does not match the SRID of the column",true)
insert into geo_srid_value_bad values (st_geomfromtext('POINT(1 1)', 0));
drop table geo_srid_value_bad;

-- @regex("different srids",true)
select st_distance(st_geomfromtext('POINT(0 0)', 4326), st_geomfromtext('POINT(3 4)', 3857));
-- @regex("different srids",true)
select st_distance(st_geomfromtext('MULTIPOINT((0 0),(3 0))', 4326), st_geomfromtext('POINT(2 0)', 3857));
-- @regex("different srids",true)
select st_contains(st_geomfromtext('GEOMETRYCOLLECTION(POINT(0 0),LINESTRING(2 0,4 0))', 4326), st_geomfromtext('POINT(3 0)', 3857));
-- @regex("different srids",true)
select st_within(st_geomfromtext('POINT(3 0)', 4326), st_geomfromtext('GEOMETRYCOLLECTION(POINT(0 0),LINESTRING(2 0,4 0))', 3857));
-- @regex("different srids",true)
select st_intersects(st_geomfromtext('GEOMETRYCOLLECTION(POINT(0 0),LINESTRING(0 0,2 0))', 4326), st_geomfromtext('POINT(1 0)', 3857));
-- @regex("different srids",true)
select st_disjoint(st_geomfromtext('GEOMETRYCOLLECTION(POINT(0 0),LINESTRING(2 0,4 0))', 4326), st_geomfromtext('POINT(1 1)', 3857));
-- @regex("different srids",true)
select st_touches(st_geomfromtext('MULTIPOINT((0 0),(3 3))', 4326), st_geomfromtext('LINESTRING(0 0,2 0)', 3857));
-- @regex("different srids",true)
select st_crosses(st_geomfromtext('MULTILINESTRING((0 0,2 2),(3 0,4 0))', 4326), st_geomfromtext('MULTILINESTRING((0 2,2 0),(5 0,6 0))', 3857));
-- @regex("different srids",true)
select st_overlaps(st_geomfromtext('MULTIPOINT((0 0),(1 1))', 4326), st_geomfromtext('MULTIPOINT((1 1),(2 2))', 3857));
-- @regex("different srids",true)
select st_equals(st_geomfromtext('MULTIPOINT((0 0),(1 1))', 4326), st_geomfromtext('MULTIPOINT((1 1),(0 0))', 3857));
-- @regex("different srids",true)
select st_covers(st_geomfromtext('GEOMETRYCOLLECTION(POINT(0 0),LINESTRING(2 0,4 0))', 4326), st_geomfromtext('POINT(3 0)', 3857));
-- @regex("different srids",true)
select st_coveredby(st_geomfromtext('POINT(3 0)', 4326), st_geomfromtext('GEOMETRYCOLLECTION(POINT(0 0),LINESTRING(2 0,4 0))', 3857));

-- @regex("SRID is only supported for GEOMETRY columns",true)
create table geo_srid_attr_bad(a int srid 4326);

drop table if exists geo_srid_attr_alter_bad;
create table geo_srid_attr_alter_bad(id int primary key, a int);
-- @regex("SRID is only supported for GEOMETRY columns",true)
alter table geo_srid_attr_alter_bad add column b int srid 4326;
-- @regex("SRID is only supported for GEOMETRY columns",true)
alter table geo_srid_attr_alter_bad modify column a int srid 4326;
drop table geo_srid_attr_alter_bad;

drop table if exists geo_srid_alter_bad;
create table geo_srid_alter_bad(g point not null srid 4326);
-- @regex("currently unsupport change from original geometry SRID 4326 to 0",true)
alter table geo_srid_alter_bad modify column g point not null srid 0;
drop table geo_srid_alter_bad;

drop database geo_srid_db;
