drop table if exists t_time_window;
create table t_time_window (ts timestamp primary key, v int);
insert into t_time_window values ('2026-01-01 00:00:00', 1), ('2026-01-01 00:00:30', 3), ('2026-01-01 00:01:00', 5), ('2026-01-01 00:01:30', 7);
select _wstart, _wend, approx_percentile(v, 0), approx_percentile(v, 1) from t_time_window interval(ts, 1, minute);
➤ _wstart[93,64,0]  ¦  _wend[93,64,0]  ¦  approx_percentile(v, 0)[8,54,0]  ¦  approx_percentile(v, 1)[8,54,0]  𝄀
