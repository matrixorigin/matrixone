drop table if exists t1;
create table t1(
id int primary key,
g geometry,
p point srid 4326
);
insert into t1 values
(1, st_geomfromtext('LINESTRING(0 0,1 1)'), st_geomfromtext('POINT(10 10)', 4326)),
(2, st_geomfromtext('POINT(3 4)'), st_geomfromtext('POINT(20 20)', 4326)),
(3, null, null);
select g from t1 order by id;
➤ g[-2,2147483647,0]  𝄀
LINESTRING(0 0,1 1)  𝄀
POINT(3 4)  𝄀
null
select p from t1 order by id;
➤ p[-2,2147483647,0]  𝄀
POINT(10 10)  𝄀
POINT(20 20)  𝄀
null
drop table t1;
