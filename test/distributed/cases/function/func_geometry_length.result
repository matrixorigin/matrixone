select st_length(st_geomfromtext('LINESTRING(0 0,3 4)')) as line_length;
➤ line_length[8,54,0]  𝄀
5.0
select st_length(st_geomfromtext('LINESTRING(0 0,3 4,6 4)')) as polyline_length;
➤ polyline_length[8,54,0]  𝄀
8.0
select st_length(st_geomfromtext('MULTILINESTRING((0 0,3 4),(3 4,6 8))')) as multiline_length;
➤ multiline_length[8,54,0]  𝄀
10.0
select st_length(st_geomfromtext('LINESTRING(0 0,3 4)', 4326)) as srid_line_length;
➤ srid_line_length[8,54,0]  𝄀
5.0
select st_length(st_geomfromtext(null)) as null_length;
➤ null_length[8,54,0]  𝄀
null
select st_length(st_geomfromtext('POINT(1 1)'));
-- @regex("geometry is not a LINESTRING or MULTILINESTRING", true)
invalid input: geometry is not a LINESTRING or MULTILINESTRING
