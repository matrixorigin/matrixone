select st_intersects(st_geomfromtext('POINT(1 1)'), st_geomfromtext('POINT(1 1)')) as intersects_same_point;
select st_intersects(st_geomfromtext('POINT(1 1)'), st_geomfromtext('LINESTRING(0 0,2 2)')) as intersects_point_line;
select st_intersects(st_geomfromtext('POINT(0 1)'), st_geomfromtext('POLYGON((0 0,2 0,2 2,0 2,0 0))')) as intersects_point_polygon_boundary;
select st_intersects(st_geomfromtext('LINESTRING(0 0,2 2)'), st_geomfromtext('LINESTRING(0 2,2 0)')) as intersects_cross_lines;
select st_intersects(st_geomfromtext('LINESTRING(-1 1,3 1)'), st_geomfromtext('POLYGON((0 0,2 0,2 2,0 2,0 0))')) as intersects_line_polygon;
select st_intersects(st_geomfromtext('POLYGON((0 0,2 0,2 2,0 2,0 0))'), st_geomfromtext('POLYGON((2 1,4 1,4 3,2 3,2 1))')) as intersects_touching_polygons;
select st_intersects(st_geomfromtext('POLYGON((0 0,2 0,2 2,0 2,0 0))'), st_geomfromtext('POLYGON((3 3,5 3,5 5,3 5,3 3))')) as intersects_disjoint_polygons;
select st_intersects(st_geomfromtext('LINESTRING(0 0,2 2)', 4326), st_geomfromtext('POINT(1 1)', 4326)) as intersects_srid;
select st_intersects(st_geomfromtext(null), st_geomfromtext('POINT(1 1)')) as intersects_null;
-- @regex("ST_INTERSECTS only supports POINT, LINESTRING, or POLYGON inputs",true)
select st_intersects(st_geomfromtext('MULTIPOINT((0 0),(1 1))'), st_geomfromtext('POINT(1 1)'));
-- @regex("polygons with holes are not supported",true)
select st_intersects(st_geomfromtext('POINT(3 3)'), st_geomfromtext('POLYGON((0 0,4 0,4 4,0 4,0 0),(1 1,2 1,2 2,1 2,1 1))'));
