-- valid document
select json_schema_valid('{"type":"object","properties":{"lat":{"type":"number","minimum":-90,"maximum":90}},"required":["lat"]}', '{"lat":60}');

-- missing required field
select json_schema_valid('{"type":"object","properties":{"lat":{"type":"number","minimum":-90,"maximum":90}},"required":["lat"]}', '{}');

-- value exceeds maximum
select json_schema_valid('{"type":"object","properties":{"lat":{"type":"number","minimum":-90,"maximum":90}},"required":["lat"]}', '{"lat":100}');

-- value below minimum
select json_schema_valid('{"type":"object","properties":{"lat":{"type":"number","minimum":-90,"maximum":90}},"required":["lat"]}', '{"lat":-100}');

-- without required, empty object validates
select json_schema_valid('{"type":"object","properties":{"lat":{"type":"number","minimum":-90,"maximum":90}}}', '{}');

-- number type
select json_schema_valid('{"type":"number","minimum":0,"maximum":100}', '42');
select json_schema_valid('{"type":"number","minimum":0,"maximum":100}', '200');

-- string type
select json_schema_valid('{"type":"string","minLength":2,"maxLength":5}', '"hi"');
select json_schema_valid('{"type":"string","minLength":2,"maxLength":5}', '"h"');
select json_schema_valid('{"type":"string","minLength":2,"maxLength":5}', '"too_long_string"');

-- pattern (valid regex)
select json_schema_valid('{"type":"string","pattern":"^[a-z]+$"}', '"hello"');
select json_schema_valid('{"type":"string","pattern":"^[a-z]+$"}', '"HELLO"');

-- enum
select json_schema_valid('{"type":"string","enum":["red","green","blue"]}', '"red"');
select json_schema_valid('{"type":"string","enum":["red","green","blue"]}', '"yellow"');

-- array with items
select json_schema_valid('{"type":"array","items":{"type":"number"},"minItems":1,"maxItems":3}', '[1,2,3]');
select json_schema_valid('{"type":"array","items":{"type":"number"},"minItems":1,"maxItems":3}', '[]');
select json_schema_valid('{"type":"array","items":{"type":"number"},"minItems":1,"maxItems":3}', '["a"]');

-- boolean schema (accepts anything)
select json_schema_valid('true', '"anything"');
select json_schema_valid('true', '42');
select json_schema_valid('true', '{"a":1}');

-- multipleOf
select json_schema_valid('{"type":"number","multipleOf":5}', '10');
select json_schema_valid('{"type":"number","multipleOf":5}', '7');

-- nested objects
select json_schema_valid('{"type":"object","properties":{"addr":{"type":"object","properties":{"city":{"type":"string"},"zip":{"type":"string"}},"required":["city"]}},"required":["addr"]}', '{"addr":{"city":"NYC","zip":"10001"}}');
select json_schema_valid('{"type":"object","properties":{"addr":{"type":"object","properties":{"city":{"type":"string"},"zip":{"type":"string"}},"required":["city"]}},"required":["addr"]}', '{"addr":{"zip":"10001"}}');

-- additionalProperties (allowed by default in draft 4)
select json_schema_valid('{"type":"object","properties":{"a":{"type":"number"}}}', '{"a":1,"b":"extra"}');

-- null inputs
select json_schema_valid(null, '{"a":1}');
select json_schema_valid('{"type":"object"}', null);

-- T_json input via json_object
select json_schema_valid(json_object('type', 'number', 'minimum', 0, 'maximum', 100), cast(42 as json));
select json_schema_valid(json_object('type', 'number', 'minimum', 0, 'maximum', 100), cast(200 as json));

-- validation report: valid
select json_schema_validation_report('{"type":"object","required":["name"]}', '{"name":"test"}');

-- validation report: missing required
select json_schema_validation_report('{"type":"object","required":["name","age"]}', '{"name":"test"}');

-- validation report: wrong type
select json_schema_validation_report('{"type":"object","properties":{"x":{"type":"number"}},"required":["x"]}', '{"x":"not_a_number"}');

-- validation report: out of range
select json_schema_validation_report('{"type":"number","minimum":0,"maximum":100}', '200');

-- validation report: null input
select json_schema_validation_report(null, '{}');
select json_schema_validation_report('{"type":"object"}', null);
