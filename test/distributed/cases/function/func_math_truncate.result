select truncate(null, 1), truncate(null, null);
truncate(null, 1)    truncate(null, null)
null    null
select truncate(cast(123 as signed), -2), truncate(cast(-123 as signed), -2), truncate(cast(123 as unsigned), -2);
truncate(cast(123 as signed), -2)    truncate(cast(-123 as signed), -2)    truncate(cast(123 as unsigned), -2)
100    -100    100
create table truncate_t1(
a int,
b bigint unsigned,
c double,
d decimal(10,3),
e decimal(30,6),
f int
);
insert into truncate_t1 values
