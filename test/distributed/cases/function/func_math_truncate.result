select truncate(1.223, 1), truncate(1.999, 1), truncate(1.999, 0), truncate(-1.999, 1);
truncate(1.223, 1)    truncate(1.999, 1)    truncate(1.999, 0)    truncate(-1.999, 1)
1.200    1.900    1.000    -1.900
select truncate(1.999, 0), truncate(cast(1.999 as double), 0), truncate(1.999e0, 0), truncate(cast(1.999 as decimal(10,3)), 0);
truncate(1.999, 0)    truncate(cast(1.999 as double), 0)    truncate(1.999e0, 0)    truncate(cast(1.999 as decimal(10, 3)), 0)
1.000    1.0    1.0    1.000
select truncate(122, -2), truncate(10.28 * 100, 0);
truncate(122, -2)    truncate(10.28 * 100, 0)
100    1028.00
select truncate(123.179, 1), truncate(123.179, 2), truncate(123.179, 4), truncate(123.179, 0), truncate(123.179, -1), truncate(123.179, -2), truncate(123.179, null);
