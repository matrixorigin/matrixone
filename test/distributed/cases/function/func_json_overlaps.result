drop table if exists t_json_overlaps_binary;
create table t_json_overlaps_binary (fixed binary(5), varying varbinary(5), large blob);
insert into t_json_overlaps_binary values ('[1,2]', '[2,3]', '[3,4]');
select json_overlaps(fixed, '[2]'),
json_overlaps('[2]', varying),
json_overlaps(large, varying)
from t_json_overlaps_binary;
➤ json_overlaps(fixed, [2])[-5,64,0]  ¦  json_overlaps([2], varying)[-5,64,0]  ¦  json_overlaps(large, varying)[-5,64,0]  𝄀
1  ¦  1  ¦  1
drop table t_json_overlaps_binary;
drop table if exists t_json_overlaps;
create table t_json_overlaps (id int, doc json, other_doc varchar(100));
insert into t_json_overlaps values
(1, '[1,2]', '[3,2]'),
(2, '{"a":1}', '{"a":2}'),
(3, null, '1'),
(4, 'null', 'null');
select id, json_overlaps(doc, other_doc) as overlap_result from t_json_overlaps order by id;
