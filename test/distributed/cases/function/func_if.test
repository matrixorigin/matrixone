CREATE TABLE test_grids_1 (
  unq_id int(11) NOT NULL DEFAULT 0,
  var_fld int(11) DEFAULT 0
);
INSERT INTO test_grids_1 VALUES
  (1,4500),
  (2,6000);
CREATE TABLE test_grid_dtl_1 (
  dtl_id int(11) NOT NULL DEFAULT 0,
  unq_id int(11) DEFAULT 0
);
INSERT INTO test_grid_dtl_1 VALUES
  (1,1),
  (2,1),
  (3,2);
SELECT g.calc_var, g.if_var, g.case_var
FROM
  (
  SELECT unq_id,
    IF ( var_fld  > 5000, (     1 / var_fld ) , 5000 ) calc_var,
    IF ( var_fld  > 5000, ( 00001 / var_fld ) , 5000 ) if_var,
    CASE  var_fld  > 5000 WHEN TRUE THEN ( 1 / var_fld ) ELSE 5000 END case_var
  FROM
    test_grids_1
  ) g
  JOIN
    test_grid_dtl_1 d USING (unq_id)
ORDER BY 1
;
DROP TABLE test_grids_1;
drop table test_grid_dtl_1;

CREATE TABLE t1(a INT,b INT,c INT);
INSERT INTO t1 VALUES(1,0,0),(1,2,0),(1,0,3),(1,2,3);
SELECT if(c = 0, if(b = 0, a, a / b), if(b = 0, a / c, a / b / c)) FROM t1;
DROP TABLE t1;

-- IF condition numeric-token semantics. The result file is generated after the implementation lands.
-- @bvt:issue
SET SESSION sql_mode = '';
SELECT IF(NULL, 'T', 'F') AS if_null_false;
SELECT IF('0', 'T', 'F') AS if_string_zero_false;
SELECT IF('  -2.5 ', 'T', 'F') AS if_string_decimal_true;
SELECT IF('+0x10', 'T', 'F') AS if_hex_positive_true;
SELECT IF('-0x10', 'T', 'F') AS if_hex_negative_true;
SELECT IF('0b1010', 'T', 'F') AS if_binary_prefix_true;
SELECT IF('0o17', 'T', 'F') AS if_octal_prefix_true;
SELECT IF('NaN', 'T', 'F') AS if_nan_true;
SELECT IF('Inf', 'T', 'F') AS if_inf_true;

-- Numeric conditions use nonzero truth semantics, including DECIMAL and BIT.
SELECT IF(CAST(0 AS DOUBLE), 'T', 'F') AS if_double_zero_false;
SELECT IF(CAST(-0.1 AS DOUBLE), 'T', 'F') AS if_double_nonzero_true;
SELECT IF(1E0, 'T', 'F') AS if_double_exponent_true;
SELECT IF(CAST(0 AS DECIMAL(3,1)), 'T', 'F') AS if_decimal_zero_false;
SELECT IF(CAST(0.1 AS DECIMAL(3,1)), 'T', 'F') AS if_decimal_nonzero_true;
CREATE TABLE if_condition_bit(id INT, b BIT(1));
INSERT INTO if_condition_bit VALUES (1, b'0'), (2, b'1'), (3, NULL);
SELECT IF(b, 'T', 'F') AS if_bit_zero_false FROM if_condition_bit WHERE id = 1;
SELECT IF(b, 'T', 'F') AS if_bit_nonzero_true FROM if_condition_bit WHERE id = 2;
SELECT IF(b, 'T', 'F') AS if_bit_null_false FROM if_condition_bit WHERE id = 3;
DROP TABLE if_condition_bit;

-- IsBin=true vectors preserve raw-byte conversion. Fixed BINARY padding from
-- a text cast remains part of the text token and makes full-token parsing fail.
SELECT IF(CAST('0x10' AS VARBINARY), 'T', 'F') AS if_varbinary_hex_true;
SELECT IF(CAST('0x10' AS BLOB), 'T', 'F') AS if_blob_hex_true;
SELECT IF(X'3136', 'T', 'F') AS if_binary_text_16_true;
SELECT IF(X'10', 'T', 'F') AS if_raw_binary_byte_true;
SELECT IF(CAST('0x10' AS BINARY(8)), 'T', 'F') AS if_fixed_binary_padding_error;

-- Default mode follows MySQL Item::val_bool/string-to-DOUBLE numeric-prefix
-- behavior while keeping MatrixOne extensions.
SELECT IF('1abc', 'T', 'F') AS if_decimal_prefix_default_true;
SELECT IF('abc', 'T', 'F') AS if_invalid_string_default_false;
SELECT IF('  -2.5foo', 'T', 'F') AS if_signed_prefix_default_true;
SELECT IF('', 'T', 'F') AS if_empty_string_default_false;
SELECT IF('   ', 'T', 'F') AS if_whitespace_default_false;
SELECT IF('.5xyz', 'T', 'F') AS if_fraction_prefix_default_true;
SELECT IF('1e2foo', 'T', 'F') AS if_exponent_prefix_default_true;
SELECT IF('1eabc', 'T', 'F') AS if_malformed_exponent_default_true;
SELECT IF('-0suffix', 'T', 'F') AS if_signed_zero_prefix_default_false;
SELECT IF('1e10000', 'T', 'F') AS if_float_overflow_default_true;
SELECT IF('0x', 'T', 'F') AS if_missing_hex_digits_default_error;
SELECT CAST('1abc' AS DOUBLE) AS cast_decimal_prefix_default;
SELECT CAST('abc' AS DOUBLE) AS cast_invalid_string_default_zero;
SELECT CAST('  -2.5foo' AS DOUBLE) AS cast_signed_prefix_default;
SELECT CAST('' AS DOUBLE) AS cast_empty_string_default_zero;
PREPARE if_mode_literal FROM 'SELECT IF(''1abc'', ''T'', ''F'') AS prepared_if_literal';
EXECUTE if_mode_literal;
SET @if_mode_value = '1eabc';
PREPARE if_mode_parameter FROM 'SELECT IF(?, ''T'', ''F'') AS prepared_if_parameter';
EXECUTE if_mode_parameter USING @if_mode_value;

-- MATRIXONE_NATIVE requires complete tokens while preserving MatrixOne numeric extensions.
SET SESSION sql_mode = 'MATRIXONE_NATIVE';
SELECT IF('0x10', 'T', 'F') AS if_hex_native_true;
SELECT IF('0b1010', 'T', 'F') AS if_binary_prefix_native_true;
SELECT IF('0o17', 'T', 'F') AS if_octal_prefix_native_true;
SELECT IF('NaN', 'T', 'F') AS if_nan_native_true;
SELECT IF('Inf', 'T', 'F') AS if_inf_native_true;
SELECT IF('1abc', 'T', 'F') AS if_decimal_prefix_native_error;
SELECT IF('abc', 'T', 'F') AS if_invalid_string_native_error;
SELECT IF('  -2.5foo', 'T', 'F') AS if_signed_suffix_native_error;
SELECT IF('', 'T', 'F') AS if_empty_string_native_error;
SELECT IF('   ', 'T', 'F') AS if_whitespace_native_error;
SELECT IF('.5xyz', 'T', 'F') AS if_fraction_suffix_native_error;
SELECT IF('1e2foo', 'T', 'F') AS if_exponent_suffix_native_error;
SELECT IF('1eabc', 'T', 'F') AS if_malformed_exponent_native_error;
SELECT IF('-0suffix', 'T', 'F') AS if_signed_zero_suffix_native_error;
SELECT IF('true', 'T', 'F') AS if_bool_text_native_error;
SELECT IF('0x', 'T', 'F') AS if_missing_hex_digits_native_error;
SELECT IF('1e10000', 'T', 'F') AS if_float_overflow_native_error;
SELECT CAST('1abc' AS DOUBLE) AS cast_decimal_prefix_native_error;
SELECT CAST('abc' AS DOUBLE) AS cast_invalid_string_native_error;
SELECT CAST('  -2.5foo' AS DOUBLE) AS cast_signed_suffix_native_error;
SELECT CAST('' AS DOUBLE) AS cast_empty_string_native_error;
EXECUTE if_mode_literal;
EXECUTE if_mode_parameter USING @if_mode_value;

-- Session sql_mode changes apply per statement and restore compatible behavior after reset.
SET SESSION sql_mode = '';
SELECT IF('1abc', 'T', 'F') AS if_decimal_prefix_after_reset_true;
SELECT IF('abc', 'T', 'F') AS if_invalid_string_after_reset_false;
EXECUTE if_mode_literal;
EXECUTE if_mode_parameter USING @if_mode_value;
DEALLOCATE PREPARE if_mode_literal;
DEALLOCATE PREPARE if_mode_parameter;
SET SESSION sql_mode = default;

CREATE TABLE t1(id INT);
INSERT INTO t1 VALUES(1),(2),(3);
SELECT CASE WHEN id = 1 THEN 'string' WHEN id = 2 THEN 123 ELSE 'mixed' END AS mixed_case FROM t1 ORDER BY id;
DROP TABLE t1;

-- Vector branches use a lossless common type and require equal dimensions.
SELECT IF(FALSE,
          CAST('[0,0]' AS VECF32(2)),
          CAST('[1.0000000001,2]' AS VECF64(2))) AS vec64_from_false;
SELECT IF(TRUE,
          CAST('[1.0000000001,2]' AS VECF64(2)),
          CAST('[0,0]' AS VECF32(2))) AS vec64_from_true;
SELECT IF(FALSE,
          CAST('[1,2]' AS VECF32(2)),
          CAST('[3,4,5]' AS VECF32(3))) AS invalid_vector_dimensions;

-- @bvt:issue#25314
SET SESSION sql_mode = '';
SELECT IF(0, CAST('bad' AS SIGNED), 7) AS if_skip_true_branch,
       CASE WHEN 0 THEN CAST('bad' AS SIGNED) ELSE 7 END AS case_skip_then,
       COALESCE(5, CAST('bad' AS SIGNED)) AS coalesce_skip_later,
       IFNULL(5, CAST('bad' AS SIGNED)) AS ifnull_skip_later;
-- @bvt:issue

# reset
SET TIME_ZONE = "SYSTEM";
