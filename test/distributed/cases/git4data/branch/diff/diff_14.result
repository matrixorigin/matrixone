drop database if exists test_diff_save_decimal;
create database test_diff_save_decimal;
use test_diff_save_decimal;
create table decimal_base(
id int primary key,
d64 decimal(18,2),
d128 decimal(19,3),
d256 decimal(39,4)
);
insert into decimal_base values
(1, 1234567890123456.78, 1234567890123456.789, 12345678901234567890123456789012345.6789),
(3, 45.67, 1234567890123456.333, 12345678901234567890123456789012343.3333);
data branch create table decimal_branch from decimal_base;
update decimal_branch
set d64 = 2234567890123456.78,
d128 = 2234567890123456.789,
d256 = 1234567890123456789012345678901234.6789
where id = 1;
insert into decimal_branch values
(2, 15.00, 1234567890123456.125, 12345678901234567890123456789012344.1234);
delete from decimal_branch where id = 3;
set save_query_result = on;
data branch diff decimal_branch against decimal_base;
diff decimal_branch against decimal_base    flag    id    d64    d128    d256
decimal_branch    UPDATE    1    2234567890123456.78    2234567890123456.789    1234567890123456789012345678901234.6789
decimal_branch    INSERT    2    15.00    1234567890123456.125    12345678901234567890123456789012344.1234
decimal_branch    DELETE    3    45.67    1234567890123456.333    12345678901234567890123456789012343.3333
set save_query_result = off;
drop table decimal_branch;
drop table decimal_base;
drop database test_diff_save_decimal;
