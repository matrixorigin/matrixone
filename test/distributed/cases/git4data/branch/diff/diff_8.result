3
data branch diff c2{snapshot="c2_sp1"} against c2{snapshot="c2_sp0"};
➤ diff c2 against c2[12,0,0]  ¦  flag[12,0,0]  ¦  a[4,0,0]  ¦  b[4,0,0]  𝄀
c2  ¦  UPDATE  ¦  2  ¦  200  𝄀
c2  ¦  DELETE  ¦  3  ¦  30  𝄀
c2  ¦  INSERT  ¦  4  ¦  40
drop snapshot c2_sp0;
drop snapshot c2_sp1;
drop table c2;
create table c3_base(a int primary key, b int);
