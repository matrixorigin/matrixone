diff c3_tar against c3_base	flag	a	b
c3_tar	UPDATE	1	101
c3_tar	DELETE	2	2
c3_tar	INSERT	4	4
data branch diff c3_base{snapshot="c3_sp0"} against c3_tar output summary;
metric	c3_base{snapshot = 'c3_sp0'}	c3_tar
INSERTED	0	1
DELETED	0	1
UPDATED	0	1
data branch diff c3_base{snapshot="c3_sp0"} against c3_tar output count;
COUNT(*)
3
drop snapshot c3_sp0;
drop table c3_base;
drop table c3_tar;
