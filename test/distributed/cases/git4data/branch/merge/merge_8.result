UPDATED    1    0
data branch merge t1 into t0;
select * from t0 order by a;
a    b
1    101
3    3
4    4
5    5
data branch diff t1 against t0 output summary;
metric    t1    t0
INSERTED    0    0
DELETED    0    0
UPDATED    0    0
data branch diff t2 against t0 output summary;
metric    t2    t0
INSERTED    0    0
