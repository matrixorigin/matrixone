SET experimental_cagra_index = 1;
SET cagra_threads_build = 7;
SET cagra_max_index_capacity = 99999;
drop database if exists cagra_postfilter;
create database cagra_postfilter;
use cagra_postfilter;
create table t (id bigint primary key, v vecf32(8), c_inc int, c_noinc int);
