create index ix using ivfpq on t (v) op_type 'vector_l2_ops' lists=2 m=8 bits_per_code=8;
select id from t order by l2_distance(v, '[5,5,5,5,5,5,5,5]') asc limit 1;
➤ id[-5,64,0]  𝄀
5
